<div class="container" style="padding: 80px 20px;">
  <div class="section-header text-center" style="margin-bottom: 60px;">
    {% if search.performed %}
      <h1 class="h2" style="font-size: 32px; color: var(--deep-forest);">
        {{ 'templates.search.results_with_count' | t: terms: search.terms, count: search.results_count | default: 'Search Results for "' | append: search.terms | append: '"' }}
      </h1>
      <p style="opacity: 0.7; margin-top: 10px;">{{ search.results_count }} results found for your search.</p>
    {% else %}
      <h1 class="h2" style="font-size: 32px; color: var(--deep-forest);">{{ 'general.search.search' | t | default: 'Search Our Store' }}</h1>
    {% endif %}
  </div>

  <div class="search-form-wrap" style="max-width: 600px; margin: 0 auto 80px;">
    <form action="/search" method="get" role="search" style="display: flex; gap: 10px;">
      <input type="hidden" name="type" value="product">
      <input 
        type="search" 
        name="q" 
        value="{{ search.terms | escape }}" 
        placeholder="Search for products (e.g. Desi Ghee)..." 
        style="flex: 1; padding: 15px 25px; border: 2px solid #EEE; border-radius: 50px; font-size: 16px; outline: none; transition: border-color 0.3s ease;"
        onfocus="this.style.borderColor='var(--deep-forest)'"
        onblur="this.style.borderColor='#EEE'"
      >
      <button type="submit" class="btn-pill btn-forest" style="padding: 15px 30px; font-size: 16px;">Search</button>
    </form>
  </div>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="search-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <div class="product-card-v2" onclick="location.href='{{ item.url }}'">
              <div class="card-image-area">
                {% if item.featured_image != blank %}
                  <img src="{{ item.featured_image | img_url: '600x' }}" alt="{{ item.title }}">
                {% else %}
                  <div style="background: #EEE; width: 100%; height: 100%; display: flex; align-items:center; justify-content:center; color: #999;">No Image</div>
                {% endif %}
              </div>
              <div class="card-content">
                <div class="stars-line">⭐⭐⭐⭐⭐ <span>(2134)</span></div>
                <h3 class="card-title">{{ item.title }}</h3>
                <p class="card-desc">{{ item.description | strip_html | truncate: 100 }}</p>
                <div class="card-price-row">
                  <span class="curr-price">{{ item.price | money }}</span>
                  {% if item.compare_at_price > item.price %}
                    <span class="old-price">{{ item.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="text-center" style="padding: 40px 0;">
        <p style="font-size: 18px; opacity: 0.6;">{{ 'templates.search.no_results' | t: terms: search.terms | default: 'No results found for your search.' }}</p>
        <a href="/collections/all" class="btn-pill btn-forest" style="margin-top: 30px; text-decoration: none;">Browse Collections</a>
      </div>
    {% endif %}
  {% endif %}
</div>

<style>
  .search-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }
  
  .product-card-v2 {
    padding: 0;
    text-align: left;
    background: white;
    border: 1px solid #EEE;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .product-card-v2:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    border-color: #004225;
  }
  
  .card-image-area {
    background-color: #FAFAFA;
    border-radius: 20px 20px 0 0;
    position: relative;
    padding: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 280px;
  }
  
  .card-image-area img {
    width: 100%;
    max-height: 220px;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  
  .card-content {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .stars-line {
    font-size: 11px;
    color: #D4AF37;
    margin-bottom: 12px;
    display: flex;
    gap: 5px;
    align-items: center;
  }
  
  .review-count {
    color: #888;
    font-weight: 500;
  }
  
  .card-title {
    font-size: 20px;
    margin-bottom: 10px;
    color: #333;
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
  }
  
  .card-desc {
    font-size: 13px;
    color: #777;
    line-height: 1.6;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-price-row {
    margin-top: auto;
    display: flex;
    gap: 12px;
    align-items: center;
  }
  
  .curr-price {
    font-weight: 800;
    font-size: 20px;
    color: #004225;
  }
  
  .old-price {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .search-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .search-grid { grid-template-columns: 1fr; }
    .search-form-wrap form { flex-direction: column; }
    .search-form-wrap button { width: 100%; }
    .card-image-area { min-height: 240px; }
  }
</style>
