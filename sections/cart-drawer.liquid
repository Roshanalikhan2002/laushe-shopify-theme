{% schema %}
{
  "name": "Cart Drawer (Laushe)",
  "settings": [
    { "id": "free_shipping_threshold", "type": "number", "label": "Free Shipping Threshold (Rs.)", "default": 3000 }
  ]
}
{% endschema %}

<!-- OVERLAY: separate element, so its blur doesn't affect the drawer -->
<div id="LausheCartOverlay" class="laushe-cart-overlay" onclick="LausheCart.close()"></div>

<!-- DRAWER PANEL: independent fixed element, slides from right -->
<div id="LausheCartDrawer" class="laushe-cart-panel">

  <div class="drawer-header">
    <h2 class="drawer-title">Your Cart</h2>
    <button class="drawer-close" onclick="LausheCart.close()">&times;</button>
  </div>

  <div id="CartProgress" class="drawer-progress">
    <p id="ProgressText" class="progress-text">Loading cart...</p>
    <div class="progress-bar-bg">
      <div id="ProgressBar" class="progress-bar-fill"></div>
    </div>
  </div>

  <div id="CartDrawerItems" class="drawer-body">
    <div style="text-align:center; padding: 30px; color:#888;">Loading...</div>
  </div>

  <form action="/cart" method="post" id="CartDrawerFooter" class="drawer-footer" style="display:none;">
    <div class="footer-row">
      <span class="total-label">Subtotal</span>
      <span id="CartDrawerTotal" class="total-value">Rs. 0</span>
    </div>
    <p class="footer-note">Shipping &amp; taxes calculated at checkout</p>
    <button type="submit" name="checkout" class="checkout-btn">Checkout Now &rarr;</button>
    <button type="button" class="continue-btn" onclick="LausheCart.close()">Continue Shopping</button>
  </form>

</div>

<style>
  /* ===== OVERLAY ===== */
  .laushe-cart-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.55);
    z-index: 88888;
    cursor: pointer;
  }
  .laushe-cart-overlay.active { display: block; }

  /* ===== DRAWER PANEL ===== */
  .laushe-cart-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 96vw;
    height: 100%;
    background: #ffffff;
    z-index: 99999;
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.18);
    transform: translateX(110%);
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .laushe-cart-panel.active {
    transform: translateX(0);
  }

  /* Header */
  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 24px;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
    background: #fff;
  }
  .drawer-title {
    font-size: 20px;
    font-weight: 800;
    color: #004225;
    margin: 0;
    font-family: 'Poppins', sans-serif;
  }
  .drawer-close {
    background: none;
    border: none;
    font-size: 30px;
    color: #aaa;
    cursor: pointer;
    line-height: 1;
    padding: 0 4px;
    transition: color 0.2s;
  }
  .drawer-close:hover { color: #333; }

  /* Progress */
  .drawer-progress {
    padding: 14px 24px;
    background: #f8fbf8;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }
  .progress-text {
    font-size: 13px;
    font-weight: 600;
    color: #555;
    text-align: center;
    margin: 0 0 8px;
  }
  .progress-bar-bg {
    height: 7px;
    background: #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: #004225;
    width: 0%;
    transition: width 0.6s ease;
    border-radius: 10px;
  }

  /* Body / Items */
  .drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
  }
  .cart-item {
    display: flex;
    gap: 14px;
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 1px solid #f5f5f5;
  }
  .cart-item:last-child { border-bottom: none; }
  .item-img {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 10px;
    background: #f5f5f5;
    flex-shrink: 0;
  }
  .item-info { flex: 1; min-width: 0; }
  .item-title {
    font-size: 14px;
    font-weight: 700;
    color: #004225;
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .item-price { font-size: 13px; color: #666; font-weight: 600; margin-bottom: 8px; }
  .item-controls { display: flex; align-items: center; gap: 10px; }
  .qty-selector { display: flex; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; }
  .qty-btn {
    width: 28px; height: 28px;
    background: #fff; border: none; cursor: pointer; font-size: 16px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    color: #333; transition: background 0.15s;
  }
  .qty-btn:hover { background: #f5f5f5; }
  .qty-val {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #333;
    border-left: 1px solid #ddd; border-right: 1px solid #ddd;
  }
  .item-remove { font-size: 12px; color: #e44; text-decoration: underline; cursor: pointer; }

  /* Footer */
  .drawer-footer {
    padding: 18px 24px;
    border-top: 1px solid #eee;
    background: #fff;
    flex-shrink: 0;
  }
  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .total-label { font-size: 16px; font-weight: 700; color: #333; }
  .total-value { font-size: 18px; font-weight: 800; color: #004225; }
  .footer-note { font-size: 12px; color: #999; text-align: center; margin-bottom: 12px; }
  .checkout-btn {
    display: block; width: 100%; padding: 15px;
    background: #004225; color: white; border: none;
    border-radius: 50px; font-size: 16px; font-weight: 800;
    cursor: pointer; margin-bottom: 8px; font-family: 'Poppins', sans-serif;
    transition: background 0.2s, transform 0.2s;
    text-align: center;
  }
  .checkout-btn:hover { background: #002b1b; transform: translateY(-2px); }
  .continue-btn {
    display: block; width: 100%; background: none; border: none;
    color: #888; font-size: 13px; cursor: pointer; text-decoration: underline;
    font-family: 'Poppins', sans-serif; text-align: center; padding: 4px;
  }
  .empty-state { text-align: center; padding: 50px 20px; }
  .empty-msg { font-size: 15px; color: #888; margin-bottom: 20px; }

  @media (max-width: 480px) {
    .laushe-cart-panel { width: 100%; max-width: 100%; }
  }
</style>

<script>
  window.LausheCart = {
    threshold: {{ section.settings.free_shipping_threshold | default: 3000 }},

    open: function() {
      document.getElementById('LausheCartOverlay').classList.add('active');
      document.getElementById('LausheCartDrawer').classList.add('active');
      document.body.style.overflow = 'hidden';
      this.refresh();
    },

    close: function() {
      document.getElementById('LausheCartOverlay').classList.remove('active');
      document.getElementById('LausheCartDrawer').classList.remove('active');
      document.body.style.overflow = '';
    },

    refresh: function() {
      fetch('/cart.js')
        .then(function(res) { return res.json(); })
        .then(function(cart) { LausheCart.render(cart); })
        .catch(function(e) { console.error('Cart refresh error:', e); });
    },

    fmt: function(cents) {
      return 'Rs. ' + Math.round(cents / 100).toLocaleString('en-PK');
    },

    render: function(cart) {
      var itemsEl = document.getElementById('CartDrawerItems');
      var totalEl = document.getElementById('CartDrawerTotal');
      var bar = document.getElementById('ProgressBar');
      var barText = document.getElementById('ProgressText');
      var footer = document.getElementById('CartDrawerFooter');
      if (!itemsEl) return;

      var totalRs = 0;
      cart.items.forEach(function(i) {
        if (!i.properties || !i.properties._is_gift) {
          totalRs += (i.final_line_price / 100);
        }
      });
      
      if (totalEl) totalEl.innerText = 'Rs. ' + totalRs.toLocaleString('en-PK');

      if (bar && barText) {
        var pct = Math.min((totalRs / this.threshold) * 100, 100);
        bar.style.width = pct + '%';
        if (totalRs >= this.threshold) {
          barText.innerHTML = "&#10024; You've unlocked <strong>FREE SHIPPING!</strong>";
          bar.style.background = '#4caf50';
        } else {
          var rem = this.threshold - totalRs;
          barText.innerHTML = "You're <strong>Rs. " + Math.round(rem).toLocaleString() + "</strong> away from FREE shipping!";
          bar.style.background = '#004225';
        }
      }

      if (cart.item_count === 0) {
        itemsEl.innerHTML = '<div class="empty-state"><p class="empty-msg">Your cart is empty.</p><button class="checkout-btn" onclick="LausheCart.close()">Keep Shopping</button></div>';
        if (footer) footer.style.display = 'none';
        return;
      }

      if (footer) footer.style.display = 'block';

      itemsEl.innerHTML = cart.items.map(function(item) {
        var isGift = (item.properties && item.properties._is_gift === 'true');
        var priceDisplay = isGift ? '<span style="color: #2d7a4f; font-weight: 800;">FREE GIFT</span>' : LausheCart.fmt(item.original_line_price);
        
        return '<div class="cart-item" data-key="' + item.key + '">' +
          '<img src="' + (item.image || '') + '" class="item-img" alt="' + item.title + '">' +
          '<div class="item-info">' +
            '<a href="' + item.url + '" class="item-title">' + item.product_title + '</a>' +
            '<div class="item-price">' + priceDisplay + '</div>' +
            '<div class="item-controls">' +
              '<div class="qty-selector">' +
                '<button class="qty-btn" onclick="LausheCart.changeQty(\'' + item.key + '\',' + (item.quantity - 1) + ')">&#8722;</button>' +
                '<div class="qty-val">' + item.quantity + '</div>' +
                '<button class="qty-btn" onclick="LausheCart.changeQty(\'' + item.key + '\',' + (item.quantity + 1) + ')">+</button>' +
              '</div>' +
              '<span class="item-remove" onclick="LausheCart.changeQty(\'' + item.key + '\',0)">Remove</span>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      // Also update header counter
      document.querySelectorAll('.header-cart-count').forEach(function(el) {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count > 0 ? 'flex' : 'none';
      });
    },

    changeQty: function(key, qty) {
      var el = document.querySelector('[data-key="' + key + '"]');
      if (el) el.style.opacity = '0.4';
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) { LausheCart.render(cart); });
    }
  };

  // Listen for cart:updated events from product pages
  document.addEventListener('cart:updated', function() {
    LausheCart.open();
  });
</script>
