{% schema %}
{
  "name": "Cart Drawer (Laushe)",
  "settings": [
    { "id": "free_shipping_threshold", "type": "number", "label": "Free Shipping Threshold (Rs.)", "default": 3000 },
    { "id": "drawer_bg", "type": "color", "label": "Drawer Background", "default": "#ffffff" }
  ]
}
{% endschema %}

<div id="LausheCartDrawer" class="cart-drawer-wrapper">
  <div class="cart-drawer-overlay" onclick="LausheCart.close()"></div>
  <div class="cart-drawer" style="background-color: {{ section.settings.drawer_bg }};">
    
    <!-- HEADER -->
    <div class="drawer-header">
      <h2 class="drawer-title">Your Cart</h2>
      <button class="drawer-close" onclick="LausheCart.close()">&times;</button>
    </div>

    <!-- FREE SHIPPING PROGRESS -->
    <div id="CartProgress" class="drawer-progress">
      <p id="ProgressText" class="progress-text">You're Rs. 0 away from FREE shipping!</p>
      <div class="progress-bar-bg">
        <div id="ProgressBar" class="progress-bar-fill"></div>
      </div>
    </div>

    <!-- BODY (Items) -->
    <div id="CartDrawerItems" class="drawer-body">
      <!-- Items dynamically rendered via JS -->
      <div class="cart-loading">Loading your cart...</div>
    </div>

    <!-- FOOTER (Total & Checkout) -->
    <form action="/cart" method="post" id="CartDrawerFooter" class="drawer-footer">
      <div class="footer-row">
        <span class="total-label">Subtotal</span>
        <span id="CartDrawerTotal" class="total-value">Rs. 0.00</span>
      </div>
      <p class="footer-note">Shipping & taxes calculated at checkout</p>
      <button type="submit" name="checkout" class="checkout-btn">Checkout Now</button>
      <button type="button" class="continue-shopping" onclick="LausheCart.close()">Continue Shopping</button>
    </form>

  </div>
</div>

<style>
  :root {
    --laushe-green: #004225;
    --laushe-dark: #002b1b;
    --laushe-gold: #D4AF37;
  }

  .cart-drawer-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .cart-drawer-wrapper.open {
    visibility: visible;
  }

  .cart-drawer-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 10;
  }

  .cart-drawer-wrapper.open .cart-drawer-overlay {
    opacity: 1;
  }

  .cart-drawer {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 450px;
    height: 100%;
    background: white;
    box-shadow: -10px 0 50px rgba(0,0,0,0.1);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    z-index: 20;
  }

  .cart-drawer-wrapper.open .cart-drawer {
    transform: translateX(0);
  }

  /* Header */
  .drawer-header {
    padding: 25px;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .drawer-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--laushe-green);
    margin: 0;
    font-family: 'Poppins', sans-serif;
  }

  .drawer-close {
    background: none;
    border: none;
    font-size: 32px;
    color: #999;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }

  .drawer-close:hover { color: #333; }

  /* Progress Bar */
  .drawer-progress {
    padding: 20px 25px;
    background: #f9fbf9;
    border-bottom: 1px solid #f0f0f0;
  }

  .progress-text {
    font-size: 13px;
    font-weight: 600;
    color: #555;
    margin-bottom: 10px;
    text-align: center;
  }

  .progress-bar-bg {
    height: 8px;
    background: #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--laushe-green);
    width: 0%;
    transition: width 0.6s ease;
  }

  /* Items */
  .drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 25px;
  }

  .cart-item {
    display: flex;
    gap: 15px;
    margin-bottom: 25px;
    position: relative;
  }

  .item-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
    background: #f7f7f7;
  }

  .item-info {
    flex: 1;
  }

  .item-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--laushe-green);
    margin: 0 0 5px;
    text-decoration: none;
    display: block;
  }

  .item-price {
    font-size: 14px;
    font-weight: 600;
    color: #666;
    margin-bottom: 10px;
  }

  .item-controls {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .qty-selector {
    display: flex;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
  }

  .qty-btn {
    width: 30px;
    height: 30px;
    background: white;
    border: none;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .qty-btn:hover { background: #f5f5f5; }

  .qty-val {
    width: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    border-left: 1px solid #e0e0e0;
    border-right: 1px solid #e0e0e0;
  }

  .item-remove {
    font-size: 12px;
    color: #ff4747;
    text-decoration: underline;
    cursor: pointer;
    font-weight: 600;
  }

  /* Footer */
  .drawer-footer {
    padding: 25px;
    border-top: 1px solid #f0f0f0;
    background: white;
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    font-family: 'Poppins', sans-serif;
  }

  .total-label { font-size: 18px; font-weight: 800; color: #333; }
  .total-value { font-size: 20px; font-weight: 800; color: var(--laushe-green); }

  .footer-note { font-size: 12px; color: #999; text-align: center; margin-bottom: 20px; }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 18px;
    background: var(--laushe-green);
    color: white;
    text-align: center;
    text-decoration: none;
    font-weight: 800;
    font-size: 16px;
    border-radius: 12px;
    margin-bottom: 10px;
    transition: all 0.3s;
  }

  .checkout-btn:hover {
    background: var(--laushe-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,66,37,0.15);
  }

  .continue-shopping {
    width: 100%;
    background: none;
    border: none;
    color: #777;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
  }

  .empty-state { text-align: center; padding: 50px 0; }
  .empty-icon { font-size: 60px; color: #eee; margin-bottom: 20px; display: block; }
  .empty-msg { font-size: 16px; color: #888; margin-bottom: 30px; }

  @media (max-width: 480px) {
    .cart-drawer { max-width: 90%; }
  }
</style>

<script>
  window.LausheCart = {
    threshold: {{ section.settings.free_shipping_threshold | default: 3000 }},
    
    open: function() {
      document.getElementById('LausheCartDrawer').classList.add('open');
      document.body.style.overflow = 'hidden';
      this.refresh();
    },

    close: function() {
      document.getElementById('LausheCartDrawer').classList.remove('open');
      document.body.style.overflow = '';
    },

    refresh: function() {
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => this.render(cart));
    },

    formatMoney: function(cents) {
      // Simple formatter for Rs. (can be improved with Shopify.formatMoney if loaded)
      return "Rs. " + (cents / 100).toLocaleString();
    },

    render: function(cart) {
      const itemsContainer = document.getElementById('CartDrawerItems');
      const totalElement = document.getElementById('CartDrawerTotal');
      const progressBar = document.getElementById('ProgressBar');
      const progressText = document.getElementById('ProgressText');
      const footer = document.getElementById('CartDrawerFooter');

      if (!itemsContainer || !cart) return;

      // Update Total
      if (totalElement) totalElement.innerText = this.formatMoney(cart.total_price);

      // Update Progress Bar
      if (progressBar && progressText) {
        const totalRs = cart.total_price / 100;
        const percent = Math.min((totalRs / this.threshold) * 100, 100);
        progressBar.style.width = percent + "%";
        
        if (totalRs >= this.threshold) {
          progressText.innerHTML = "\u2728 You've unlocked <strong>FREE SHIPPING!</strong>";
          progressBar.style.background = "#4caf50";
        } else {
          const remaining = this.threshold - totalRs;
          progressText.innerHTML = `You're <strong>Rs. ${remaining.toLocaleString()}</strong> away from FREE shipping!`;
          progressBar.style.background = "var(--laushe-green)";
        }
      }

      if (cart.item_count === 0) {
        itemsContainer.innerHTML = `
          <div class="empty-state">
            <ion-icon name="cart-outline" class="empty-icon"></ion-icon>
            <p class="empty-msg">Your cart is currently empty.</p>
            <button class="checkout-btn" onclick="LausheCart.close()">Start Shopping</button>
          </div>
        `;
        if (footer) footer.style.display = 'none';
        return;
      }

      if (footer) footer.style.display = 'block';

      itemsContainer.innerHTML = cart.items.map(item => `
        <div class="cart-item" data-key="${item.key}">
          <img src="${item.image}" class="item-img" alt="${item.title}">
          <div class="item-info">
            <a href="${item.url}" class="item-title">${item.product_title}</a>
            <div class="item-price">${this.formatMoney(item.original_line_price)}</div>
            <div class="item-controls">
              <div class="qty-selector">
                <button class="qty-btn" onclick="LausheCart.changeQty('${item.key}', ${item.quantity - 1})">\u2212</button>
                <div class="qty-val">${item.quantity}</div>
                <button class="qty-btn" onclick="LausheCart.changeQty('${item.key}', ${item.quantity + 1})">+</button>
              </div>
              <span class="item-remove" onclick="LausheCart.changeQty('${item.key}', 0)">Remove</span>
            </div>
          </div>
        </div>
      `).join('');
    },

    changeQty: function(key, qty) {
      // Visual feedback immediately
      document.querySelector(`[data-key="${key}"]`).style.opacity = '0.5';
      
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty })
      })
      .then(res => res.json())
      .then(cart => {
        this.render(cart);
        // Also update the header count
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      });
    }
  };

  // Add listener for global cart updates (from product pages or other sections)
  document.addEventListener('cart:updated', function() {
    LausheCart.open();
  });
</script>
