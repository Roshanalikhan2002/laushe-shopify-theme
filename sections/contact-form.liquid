<div class="contact-section">
  <div class="contact-container">
    <div class="contact-header">
      <h2>{{ section.settings.heading | escape }}</h2>
      <p>{{ section.settings.subtext | escape }}</p>
    </div>

    {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-status form-status-success" tabindex="-1" autofocus>
          <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 13 13" width="16" height="16">
            <path d="M6.5 12.35C3.274 12.35.65 9.725.65 6.5S3.274.65 6.5.65s5.85 2.624 5.85 5.85-2.624 5.85-5.85 5.85zm0-10.7a4.85 4.85 0 100 9.7 4.85 4.85 0 000-9.7zm-1.8 7.2l-2-2 1.4-1.4 1.3 1.3 3.1-3.1 1.4 1.4-4.5 4.5 1.3-1.3-1.3 1.3z" fill="currentColor"/>
          </svg>
          <p>Thanks for contacting us. We'll get back to you as soon as possible.</p>
        </div>
      {%- elsif form.errors -%}
        <div class="form-status form-status-error">
          <p>Please adjust the following:</p>
          <ul>
            {% for field in form.errors %}
              <li>
                {% if field == 'form' %}
                  {{ form.errors.messages[field] }}
                {% else %}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>
      {%- endif -%}

      <div class="contact-form-fields">
        <div class="field">
          <label class="field-label" for="ContactForm-name">Name</label>
          <input
            class="field-input"
            autocomplete="name"
            type="text"
            id="ContactForm-name"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            placeholder="John Doe"
          >
        </div>
        <div class="field">
          <label class="field-label" for="ContactForm-email">Email <span aria-hidden="true">*</span></label>
          <input
            autocomplete="email"
            type="email"
            id="ContactForm-email"
            class="field-input {% if form.errors contains 'email' %}field-error{% endif %}"
            name="contact[email]"
            spellcheck="false"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            aria-required="true"
            placeholder="john@example.com"
            required
          >
        </div>
      </div>
      
      <div class="field">
        <label class="field-label" for="ContactForm-phone">Phone Number (Optional)</label>
        <input
          type="tel"
          id="ContactForm-phone"
          class="field-input"
          autocomplete="tel"
          name="contact[phone]"
          pattern="[0-9\-]*"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          placeholder="+1 (555) 000-0000"
        >
      </div>

      <div class="field">
        <label class="field-label" for="ContactForm-body">Message</label>
        <textarea
          rows="5"
          id="ContactForm-body"
          class="field-input field-textarea"
          name="contact[body]"
          placeholder="How can we help you today?"
        >
          {{- form.body -}}
        </textarea>
      </div>

      <div class="contact-submit">
        <button type="submit" class="button button--primary button--full-width">
          Send Message
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

<style>
.contact-section {
  padding: 80px 20px;
  background-color: #f7fad;
  background: linear-gradient(to bottom, #ffffff, #f9fafb);
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.contact-container {
  width: 100%;
  max-width: 650px;
  background: white;
  padding: 50px;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.06);
  border: 1px solid rgba(0,0,0,0.05);
}

.contact-header {
  text-align: center;
  margin-bottom: 40px;
}

.contact-header h2 {
  font-size: 2.5rem;
  color: #111827;
  margin-bottom: 15px;
  font-family: inherit;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.contact-header p {
  color: #4b5563;
  font-size: 1.125rem;
  line-height: 1.6;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.contact-form-fields {
  display: flex;
  gap: 20px;
}

.contact-form-fields .field {
  flex: 1;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.field-label {
  font-size: 0.95rem;
  color: #374151;
  font-weight: 600;
}

.field-input {
  width: 100%;
  padding: 16px;
  border: 1.5px solid #e5e7eb;
  border-radius: 12px;
  font-size: 1rem;
  transition: all 0.2s ease;
  font-family: inherit;
  box-sizing: border-box;
  background-color: #ffffff;
}

.field-input:focus {
  outline: none;
  border-color: #10b981;
  box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
}

.field-input::placeholder {
  color: #9ca3af;
}

.field-error {
  border-color: #ef4444;
}

.field-textarea {
  resize: vertical;
  min-height: 140px;
}

.contact-submit {
  margin-top: 10px;
}

.button {
  background-color: #10b981;
  color: white;
  border: none;
  padding: 18px 36px;
  font-size: 1.15rem;
  font-weight: 600;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
  display: inline-block;
  text-align: center;
  box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);
}

.button:hover {
  background-color: #059669;
  box-shadow: 0 6px 12px rgba(16, 185, 129, 0.3);
  transform: translateY(-1px);
}

.button:active {
  transform: translateY(1px);
  box-shadow: 0 2px 4px rgba(16, 185, 129, 0.2);
}

.button--full-width {
  width: 100%;
}

.form-status {
  padding: 16px;
  border-radius: 12px;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.form-status-success {
  background-color: #ecfdf5;
  color: #047857;
  border: 1px solid #a7f3d0;
}

.form-status-error {
  background-color: #fef2f2;
  color: #b91c1c;
  border: 1px solid #fecaca;
  flex-direction: column;
  align-items: flex-start;
}

.form-status-error ul {
  margin: 0;
  padding-left: 20px;
  margin-top: 8px;
}

@media screen and (max-width: 749px) {
  .contact-section {
    padding: 40px 15px;
  }
  
  .contact-container {
    padding: 30px 20px;
    border-radius: 16px;
  }

  .contact-form-fields {
    flex-direction: column;
    gap: 24px;
  }
  
  .contact-header h2 {
    font-size: 2rem;
  }
}
</style>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Get in Touch",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "default": "Have questions? We'd love to hear from you. Send us a message and we'll respond as soon as possible.",
      "label": "Subtext"
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
