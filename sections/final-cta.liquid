<!-- 
  Section: Final CTA Banner
  Aesthetics: Bold, high-energy, compelling
-->

{% schema %}
{
  "name": "Final CTA Banner",
  "settings": [
    {
      "id": "headline",
      "type": "text",
      "label": "Headline",
      "default": "Ready to Transform Your Health?"
    },
    {
      "id": "subtext",
      "type": "textarea",
      "label": "Subtext",
      "default": "Join over 50,000+ satisfied customers today and experience the Laushe difference."
    },
    {
      "id": "cta_text",
      "type": "text",
      "label": "CTA Text",
      "default": "SHOP NOW - SAVE 25%"
    },
    {
      "id": "cta_url",
      "type": "url",
      "label": "CTA Link"
    },
    {
       "id": "bg_color",
       "type": "color",
       "label": "Background Color",
       "default": "#1B4332"
    }
  ],
  "presets": [
     {
       "name": "Final CTA Banner",
       "category": "Custom"
     }
  ]
}
{% endschema %}

<section class="final-cta-section section-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="container-wide">
    <div class="final-cta-wrapper text-center animate-fade-up">
       <h2 class="final-cta-headline h1">{{ section.settings.headline }}</h2>
       <p class="final-cta-subtext">{{ section.settings.subtext }}</p>
       
       <div class="final-cta-actions">
          <a href="{{ section.settings.cta_url }}" class="button-primary final-btn">{{ section.settings.cta_text }}</a>
          <p class="final-trust-badge text-muted">✅ 30-Day Money Back Guarantee | ⭐ 4.9/5 Star Rating</p>
       </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    position: relative;
    overflow: hidden;
    color: #FFF;
  }
  
  .final-cta-headline {
    font-size: 3.5rem;
    color: #FFF;
    margin-bottom: 24px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .final-cta-subtext {
    font-size: 1.3rem;
    color: #F0F0F0;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .final-btn {
    font-size: 1.15rem;
    font-weight: 800;
    padding: 20px 55px;
    background: linear-gradient(135deg, #D4AF37, #F5CB5C);
    color: #1B4332;
    border: none;
    border-radius: 50px;
    text-decoration: none;
    display: inline-block;
    letter-spacing: 1px;
    text-transform: uppercase;
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.45);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  
  .final-btn:hover {
    background: linear-gradient(135deg, #F5CB5C, #D4AF37);
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(212, 175, 55, 0.6);
    color: #1B4332;
  }
  
  .final-btn:active {
    transform: translateY(0px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
  }
  
  .final-trust-badge {
    margin-top: 24px;
    color: #FFF;
    opacity: 0.8;
    font-size: 0.85rem;
    font-weight: 500;
  }
  
  @media (max-width: 768px) {
    .final-cta-headline {
      font-size: 2.5rem;
    }
    
    .final-cta-subtext {
      font-size: 1.1rem;
    }
  }
</style>
