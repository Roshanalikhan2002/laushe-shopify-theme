{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Shopping Bag"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_info",
      "label": "Show Shipping Information",
      "default": true
    }
  ]
}
{% endschema %}

<section class="main-cart-section" style="background-color: #faf7f2; min-height: 80vh; padding: 80px 0;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    <header class="cart-header" style="margin-bottom: 50px;">
      <h1 style="font-size: 42px; font-weight: 800; color: #004225; margin-bottom: 10px; font-family: 'Poppins', sans-serif;">{{ section.settings.heading }}</h1>
      <a href="/collections/all" class="continue-shopping" style="color: #666; text-decoration: none; font-weight: 600; font-size: 15px; display: flex; align-items: center; gap: 8px;">
        <span>&larr;</span> Continue Shopping
      </a>
    </header>

    {% if cart.item_count > 0 %}
      <div class="cart-layout" style="display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: start;">
        
        <!-- LEFT: ITEMS -->
        <div class="cart-items-column">
          <form action="/cart" method="post" id="cart-form">
            <div class="cart-items-list" style="background: white; border-radius: 24px; padding: 30px; box-shadow: 0 10px 40px rgba(0,0,0,0.03);">
              {% for item in cart.items %}
                <div class="cart-item" style="display: flex; gap: 25px; padding: 25px 0; {% unless forloop.last %}border-bottom: 1px solid #f0f0f0;{% endunless %}">
                  <!-- Image -->
                  <div class="item-image" style="width: 120px; height: 120px; background: #f9f9f9; border-radius: 16px; overflow: hidden; flex-shrink: 0;">
                    <img src="{{ item.image | img_url: '240x240', crop: 'center' }}" alt="{{ item.title }}" style="width: 100%; height: 100%; object-fit: contain;">
                  </div>

                  <!-- Info -->
                  <div class="item-info" style="flex-grow: 1;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                      <h3 style="font-size: 18px; font-weight: 700; color: #004225; margin: 0; font-family: 'Poppins', sans-serif;">
                        <a href="{{ item.url }}" style="color: inherit; text-decoration: none;">{{ item.product.title }}</a>
                      </h3>
                      <span style="font-size: 18px; font-weight: 700; color: #004225;">{{ item.final_line_price | money }}</span>
                    </div>

                    {% if item.variant.title != 'Default Title' %}
                      <p style="font-size: 14px; color: #888; margin-bottom: 15px;">{{ item.variant.title }}</p>
                    {% endif %}

                    <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 20px;">
                      <!-- QTY SELECTOR -->
                      <div class="qty-selector" style="display: flex; align-items: center; border: 1px solid #e0e0e0; border-radius: 50px; padding: 4px;">
                        <button type="button" class="qty-btn minus" data-id="{{ item.key }}" style="background: none; border: none; width: 32px; height: 32px; cursor: pointer; font-size: 18px; color: #004225;">&minus;</button>
                        <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width: 40px; border: none; text-align: center; font-weight: 700; color: #004225; -moz-appearance: textfield; font-size: 15px;" readonly>
                        <button type="button" class="qty-btn plus" data-id="{{ item.key }}" style="background: none; border: none; width: 32px; height: 32px; cursor: pointer; font-size: 18px; color: #004225;">&plus;</button>
                      </div>

                      <!-- REMOVE -->
                      <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="color: #ff4d4d; font-size: 13px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 5px;">
                        Remove
                      </a>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </form>
        </div>

        <!-- RIGHT: SUMMARY -->
        <aside class="cart-summary" style="background: white; border-radius: 24px; padding: 35px; box-shadow: 0 10px 40px rgba(0,0,0,0.03); position: sticky; top: 40px;">
          <h2 style="font-size: 22px; font-weight: 800; color: #004225; margin-bottom: 25px; font-family: 'Poppins', sans-serif;">Order Summary</h2>
          
          <div style="display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 16px; color: #555;">
            <span>Subtotal</span>
            <span style="font-weight: 700; color: #004225;">{{ cart.total_price | money }}</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; margin-bottom: 25px; font-size: 16px; color: #555;">
            <span>Shipping</span>
            <span style="font-weight: 600; color: #004225;">Calculated at checkout</span>
          </div>

          <div style="border-top: 1px solid #f0f0f0; padding-top: 20px; margin-bottom: 30px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 18px; font-weight: 800; color: #004225;">Total</span>
              <span style="font-size: 24px; font-weight: 800; color: #004225;">{{ cart.total_price | money }}</span>
            </div>
          </div>

          <button type="submit" form="cart-form" name="checkout" style="width: 100%; background: #004225; color: white; border: none; padding: 18px; border-radius: 14px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.3s ease; font-family: 'Poppins', sans-serif;">
            Proceed to Checkout
          </button>

          {% if section.settings.show_shipping_info %}
            <div style="margin-top: 25px; padding: 15px; background: #f8faf9; border-radius: 12px; display: flex; gap: 12px; align-items: center;">
              <div style="font-size: 20px;">🚚</div>
              <p style="font-size: 13px; color: #446; line-height: 1.4; margin: 0;">
                <strong>Free shipping</strong> on orders over Rs. 10,000. Delivery takes 3-5 business days.
              </p>
            </div>
          {% endif %}
        </aside>

      </div>
    {% else %}
      <!-- EMPTY STATE -->
      <div class="cart-empty" style="text-align: center; background: white; border-radius: 24px; padding: 80px 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.03);">
        <div style="font-size: 60px; margin-bottom: 25px;">🛒</div>
        <h2 style="font-size: 28px; font-weight: 800; color: #004225; margin-bottom: 15px;">Your bag is empty</h2>
        <p style="color: #666; margin-bottom: 35px; font-size: 16px;">Looks like you haven't added anything to your cart yet.</p>
        <a href="/collections/all" style="display: inline-block; background: #004225; color: white; text-decoration: none; padding: 16px 40px; border-radius: 50px; font-weight: 700; transition: all 0.3s ease;">
          Shop Collection
        </a>
      </div>
    {% endif %}

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cartForm = document.getElementById('cart-form');
    if (!cartForm) return;

    cartForm.addEventListener('click', (e) => {
      const btn = e.target.closest('.qty-btn');
      if (!btn) return;

      const input = btn.parentElement.querySelector('input');
      let val = parseInt(input.value);
      const isPlus = btn.classList.contains('plus');
      
      if (isPlus) {
        val++;
      } else {
        val = Math.max(0, val - 1);
      }
      
      input.value = val;
      
      // Auto-update cart
      const variantId = btn.getAttribute('data-id');
      updateCartItem(variantId, val);
    });

    function updateCartItem(variantId, qty) {
      // Show loading if needed
      document.body.style.opacity = '0.6';
      
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(res => res.json())
      .then(data => {
        // Reload page to reflect changes
        window.location.reload();
      })
      .catch(err => {
        console.error('Cart update error:', err);
        window.location.reload();
      });
    }
  });
</script>

<style>
  @media (max-width: 1000px) {
    .cart-layout { grid-template-columns: 1fr !important; }
    .cart-summary { position: static !important; }
    .main-cart-section { padding: 40px 0 !important; }
    .cart-header h1 { font-size: 32px !important; }
  }
  @media (max-width: 600px) {
    .cart-item { flex-direction: column; align-items: center; text-align: center; }
    .item-image { width: 100% !important; height: 200px !important; }
    .item-info { width: 100%; }
    .qty-selector { justify-content: center; }
  }
</style>
