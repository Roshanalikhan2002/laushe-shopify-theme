{% schema %}
{
  "name": "Wellness Collection Grid",
  "settings": [
    { "id": "heading", "type": "text", "label": "Heading", "default": "Shop Our Entire Wellness Collection" },
    { "id": "subheading", "type": "text", "label": "Subheading", "default": "Pure, Raw, and Bio-available supplements for every stage of your health journey." },
    { "id": "collection", "type": "collection", "label": "Source Collection", "info": "Select the collection to show (e.g. 'All Products')" },
    { "type": "header", "content": "Filter Tab 1" },
    { "id": "tab1_label", "type": "text", "label": "Label", "default": "All Products" },
    { "type": "header", "content": "Filter Tab 2" },
    { "id": "tab2_label", "type": "text", "label": "Label", "default": "Healthcare" },
    { "id": "tab2_tag", "type": "text", "label": "Tag to Match", "default": "healthcare", "info": "Products must have this tag to show in this tab." },
    { "type": "header", "content": "Filter Tab 3" },
    { "id": "tab3_label", "type": "text", "label": "Label", "default": "Organic" },
    { "id": "tab3_tag", "type": "text", "label": "Tag to Match", "default": "organic", "info": "Products must have this tag to show in this tab." }
  ],
  "blocks": [
    {
      "type": "product_override",
      "name": "Product Override",
      "settings": [
        { "id": "target_product", "type": "product", "label": "Apply to this Product" },
        { "id": "title", "type": "text", "label": "Custom Title" },
        { "id": "desc", "type": "textarea", "label": "Custom Description" },
        { "id": "image", "type": "image_picker", "label": "Custom Image" },
        { "id": "price", "type": "text", "label": "Custom Price Text (e.g. Rs.2,990)" }
      ]
    }
  ],
  "presets": [{ "name": "Wellness Collection Grid", "category": "Laushe Sections" }]
}
{% endschema %}

<section class="wellness-catalog section-padding" style="background-color: #e9f3ed;" id="section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div id="laushe-shop" style="position: absolute; top: -100px;"></div>
  <div class="container">
    
    <!-- HEADER -->
    <div class="catalog-header text-center" style="margin-bottom: 60px;">
      <h2 class="catalog-title">{{ section.settings.heading }}</h2>
      <p class="catalog-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <!-- FILTER BAR -->
    <div class="catalog-filters">
      <button class="filter-btn active" data-filter="all">{{ section.settings.tab1_label }}</button>
      {% if section.settings.tab2_label != blank %}
        <button class="filter-btn" data-filter="{{ section.settings.tab2_tag | handle }}">{{ section.settings.tab2_label }}</button>
      {% endif %}
      {% if section.settings.tab3_label != blank %}
        <button class="filter-btn" data-filter="{{ section.settings.tab3_tag | handle }}">{{ section.settings.tab3_label }}</button>
      {% endif %}
    </div>

    <!-- PRODUCT GRID -->
    <div class="catalog-grid-wrapper">
      <div class="catalog-grid" id="laushe-catalog-grid-{{ section.id }}">
        {% assign target_collection = section.settings.collection | default: collections.all %}
        {% for product in target_collection.products %}
          {% if product.handle == 'golden-elixir' or product.handle == 'weight-gainer' %}
            {% continue %}
          {% endif %}
          {% assign product_tags_string = product.tags | join: ',' | downcase %}
          
          {% comment %} CHECK FOR OVERRIDES {% endcomment %}
          {% assign display_title = product.title %}
          {% assign display_desc = product.description | strip_html | truncate: 80 %}
          {% assign display_img = product.featured_image | img_url: '600x600', crop: 'center' %}
          {% assign display_price = product.price | money %}
          
          {% assign override_block = nil %}
          {% for block in section.blocks %}
            {% if block.type == 'product_override' and block.settings.target_product == product.handle %}
              {% if block.settings.title != blank %}{% assign display_title = block.settings.title %}{% endif %}
              {% if block.settings.desc != blank %}{% assign display_desc = block.settings.desc %}{% endif %}
              {% if block.settings.image != blank %}{% assign display_img = block.settings.image | img_url: '600x600', crop: 'center' %}{% endif %}
              {% if block.settings.price != blank %}{% assign display_price = block.settings.price %}{% endif %}
              {% assign override_block = block %}
            {% endif %}
          {% endfor %}
          
          <div class="catalog-item" data-tags="{{ product_tags_string }}" {{ override_block.shopify_attributes }}>
            
            <div class="catalog-card">
              <!-- Badge -->
              {% if product.compare_at_price > product.price %}
                {% assign saving = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <div class="card-badge">{{ saving }}% OFF</div>
              {% endif %}

              <!-- Image -->
              <a href="{{ product.url }}" class="card-img-link">
                <img src="{{ display_img }}" alt="{{ display_title }}" class="card-img" loading="lazy">
              </a>

              <div class="card-content">
                <!-- Stars -->
                <div class="card-stars">
                  <span class="stars-gold">★★★★★</span>
                  <span class="review-count">(2134)</span>
                </div>

                <h3 class="card-title">{{ display_title }}</h3>
                <p class="card-short-desc">{{ display_desc }}</p>

                <div class="card-price-row">
                  <span class="price-main">{{ display_price }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>

                <!-- ADD TO CART BUTTON -->
                <div class="card-atc-wrapper">
                  {% if product.available %}
                    {% assign current_variant = product.selected_or_first_available_variant %}
                    <form method="post" action="/cart/add" class="laushe-atc-form" data-product-id="{{ product.id }}">
                      <input type="hidden" name="id" value="{{ current_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="atc-btn-main">
                        <span class="atc-text">Add to Cart</span>
                        <span class="atc-loading" style="display: none;">Adding...</span>
                      </button>
                    </form>
                  {% else %}
                    <button class="atc-btn-main disabled" disabled>Out of Stock</button>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <!-- Empty State -->
      <div class="catalog-empty-state" style="display: none; text-align: center; padding: 60px 0;">
        <p style="font-size: 18px; color: #555; opacity: 0.6;">No products found with this tag.</p>
      </div>
    </div>

  </div>
</section>

<style>
  #section-{{ section.id }} .wellness-catalog { padding: 120px 0; }
  #section-{{ section.id }} .catalog-title { font-size: 40px; font-weight: 800; color: #004225; margin-bottom: 15px; font-family: 'Poppins', sans-serif; }
  #section-{{ section.id }} .catalog-subtitle { font-size: 16px; color: #555; opacity: 0.8; }
  #section-{{ section.id }} .catalog-filters { display: flex; justify-content: center; gap: 15px; margin-bottom: 60px; flex-wrap: wrap; }
  
  #section-{{ section.id }} .filter-btn {
    padding: 12px 30px;
    border-radius: 50px;
    border: none;
    background: white;
    color: #004225;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }
  
  #section-{{ section.id }} .filter-btn.active { background: #004225; color: white; box-shadow: 0 10px 20px rgba(0,66,37,0.2); }
  
  #section-{{ section.id }} .catalog-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 30px; }
  #section-{{ section.id }} .catalog-item { width: 100%; display: flex; }
  #section-{{ section.id }} .catalog-card { width: 100%; background: white; border-radius: 20px; padding: 20px; height: 100%; position: relative; transition: transform 0.3s ease; display: flex; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
  #section-{{ section.id }} .catalog-card:hover { transform: translateY(-5px); }
  
  #section-{{ section.id }} .card-badge { position: absolute; top: 20px; left: 20px; background: #D4AF37; color: white; font-size: 11px; font-weight: 800; padding: 4px 10px; border-radius: 6px; z-index: 2; }
  #section-{{ section.id }} .card-img-link { display: flex; align-items: center; justify-content: center; height: 220px; width: 100%; margin-bottom: 20px; overflow: hidden; border-radius: 12px; }
  #section-{{ section.id }} .card-img { width: 100%; height: 100%; object-fit: contain; }
  #section-{{ section.id }} .card-content { flex-grow: 1; display: flex; flex-direction: column; width: 100%; }
  #section-{{ section.id }} .card-stars { margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  #section-{{ section.id }} .stars-gold { color: #D4AF37; font-size: 14px; letter-spacing: 2px; }
  #section-{{ section.id }} .review-count { font-size: 12px; color: #888; font-weight: 500; }
  #section-{{ section.id }} .card-title { font-size: 18px; font-weight: 800; color: #004225; margin-bottom: 10px; font-family: 'Poppins', sans-serif; line-height: 1.3; }
  #section-{{ section.id }} .card-short-desc { font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  #section-{{ section.id }} .card-price-row { display: flex; align-items: center; gap: 12px; }
  #section-{{ section.id }} .price-main { font-size: 18px; font-weight: 800; color: #004225; }
  #section-{{ section.id }} .price-compare { font-size: 14px; color: #999; text-decoration: line-through; }
  
  #section-{{ section.id }} .card-atc-wrapper { margin-top: auto; padding-top: 25px; width: 100%; }
  
  #section-{{ section.id }} .atc-btn-main {
    width: 100%;
    padding: 14px;
    background: #004225;
    color: white;
    border: none;
    border-radius: 12px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    font-family: 'Poppins', sans-serif;
  }
  
  #section-{{ section.id }} .atc-btn-main:hover {
    background: #002b1b;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,66,37,0.2);
  }
  
  #section-{{ section.id }} .atc-btn-main.success {
    background: #4caf50;
  }
  
  #section-{{ section.id }} .atc-btn-main.disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  @media (max-width: 1100px) { #section-{{ section.id }} .catalog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { 
    #section-{{ section.id }} .catalog-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } 
    #section-{{ section.id }} .catalog-card { padding: 12px; }
    #section-{{ section.id }} .card-title { font-size: 14px; margin-bottom: 5px; }
    #section-{{ section.id }} .card-short-desc { font-size: 11px; height: 34px; margin-bottom: 10px; }
    #section-{{ section.id }} .price-main { font-size: 15px; }
    #section-{{ section.id }} .card-img-link { height: 160px; margin-bottom: 10px; }
    #section-{{ section.id }} .atc-btn-main { padding: 10px; font-size: 12px; border-radius: 8px; }
    #section-{{ section.id }} .catalog-title { font-size: 28px; } 
  }
</style>

<script>
  (function() {
    function applyFilter(section, filterValue) {
      const filters = section.querySelectorAll('.filter-btn');
      const items = section.querySelectorAll('.catalog-item');
      const grid = section.querySelector('.catalog-grid');
      const emptyState = section.querySelector('.catalog-empty-state');

      filters.forEach(b => b.classList.remove('active'));
      let matched = false;
      filters.forEach(btn => {
        if (btn.getAttribute('data-filter').toLowerCase() === filterValue) {
          btn.classList.add('active');
          matched = true;
        }
      });
      if (!matched) filters[0] && filters[0].classList.add('active');

      let visibleCount = 0;
      items.forEach(item => {
        if (filterValue === 'all' || !matched) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          const tags = item.getAttribute('data-tags').split(',');
          const isMatch = tags.includes(filterValue);
          item.style.display = isMatch ? 'block' : 'none';
          if (isMatch) visibleCount++;
        }
      });

      if (visibleCount === 0) {
        grid.style.display = 'none';
        emptyState.style.display = 'block';
      } else {
        grid.style.display = 'grid';
        emptyState.style.display = 'none';
      }
    }

    function initCatalogFilters() {
      const anchor = document.querySelector('#laushe-shop');
      const section = anchor ? anchor.closest('.wellness-catalog') : null;
      if (!section) return;

      const filters = section.querySelectorAll('.filter-btn');

      // Wire up click handlers
      filters.forEach(btn => {
        btn.addEventListener('click', () => {
          applyFilter(section, btn.getAttribute('data-filter').toLowerCase());
        });
      });

      // Wire up AJAX Add to Cart
      const atcForms = section.querySelectorAll('.laushe-atc-form');
      atcForms.forEach(form => {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          const btn = form.querySelector('.atc-btn-main');
          const atcText = btn.querySelector('.atc-text');
          const atcLoading = btn.querySelector('.atc-loading');

          // Visual Feedback
          atcText.style.display = 'none';
          atcLoading.style.display = 'inline';
          btn.style.opacity = '0.7';
          btn.disabled = true;

          const variantId = form.querySelector('input[name="id"]').value;

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
          })
          .then(res => {
            if (!res.ok) throw new Error('Cart add failed');
            return res.json();
          })
          .then(data => {
            // Success State
            atcLoading.style.display = 'none';
            atcText.style.display = 'inline';
            atcText.innerText = 'Added! ✓';
            btn.classList.add('success');
            btn.style.opacity = '1';

            // Trigger cart drawer if available
            if (window.LausheCart) {
              LausheCart.open();
            } else {
              document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
            }

            // Reset after 2 seconds
            setTimeout(() => {
              atcText.innerText = 'Add to Cart';
              btn.classList.remove('success');
              btn.disabled = false;
            }, 2000);
          })
          .catch(error => {
            console.error('Error adding to cart:', error);
            atcLoading.style.display = 'none';
            atcText.style.display = 'inline';
            atcText.innerText = 'Error! Try again';
            btn.disabled = false;
            btn.style.opacity = '1';
            setTimeout(() => {
               atcText.innerText = 'Add to Cart';
            }, 2500);
          });
        });
      });

      // Auto-activate filter from URL param ?filter=healthcare
      const urlParams = new URLSearchParams(window.location.search);
      const filterParam = (urlParams.get('filter') || '').toLowerCase();
      if (filterParam) {
        applyFilter(section, filterParam);
        // Smooth scroll to section
        setTimeout(() => {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 200);
      }
    }

    document.addEventListener('DOMContentLoaded', initCatalogFilters);
    document.addEventListener('shopify:section:load', initCatalogFilters);
  })();
</script>
