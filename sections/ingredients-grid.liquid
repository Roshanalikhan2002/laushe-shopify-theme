{% schema %}
{
  "name": "Ingredients Grid",
  "settings": [
    { "id": "headline", "type": "text", "label": "Headline", "default": "High-Quality, Natural Ingredients" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "id": "title", "type": "text", "label": "Name", "default": "Dried Hibiscus" },
        { "id": "desc", "type": "textarea", "label": "Function", "default": "Helps with fat reduction and digestion." }
      ]
    }
  ],
  "presets": [{ "name": "Ingredients Grid", "category": "Luxe Funnel" }]
}
{% endschema %}

<section class="section-padding bg-white" style="padding: 100px 0;">
  <div class="container-wide" style="max-width: 1280px; margin: 0 auto; padding: 0 40px;">
    <h2 class="h1 text-center" style="font-size: 44px; text-align: center; margin-bottom: 60px;">{{ section.settings.headline }}</h2>
    <div class="ingredients-grid">
      {% for block in section.blocks %}
        <div class="ingredient-item">
          <div class="ing-icon">
            <ion-icon name="leaf-outline"></ion-icon>
          </div>
          <div class="ing-content">
            <h3 class="ing-title">{{ block.settings.title }}</h3>
            <p class="ing-desc">{{ block.settings.desc }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ingredients-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .ingredient-item { display: flex; gap: 24px; align-items: flex-start; padding: 32px; border-radius: 20px; border: 1px solid #f0f0f0; transition: all 0.3s ease; background: #fff; }
  .ingredient-item:hover { border-color: #004225; box-shadow: 0 10px 40px rgba(0,66,37,0.08); transform: translateY(-3px); }
  .ing-icon { background: #f0faf4; width: 60px; height: 60px; min-width: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; color: #004225; }
  .ing-title { font-size: 19px; font-weight: 800; color: #004225; margin-bottom: 10px; font-family: 'Poppins', sans-serif; }
  .ing-desc { color: #666; font-size: 14px; line-height: 1.6; }
  @media (max-width: 768px) { .ingredients-grid { grid-template-columns: 1fr; } }
</style>

