{% schema %}
{
  "name": "Athlete endorsement",
  "settings": [
    { "id": "image", "type": "image_picker", "label": "Athlete Image" },
    { "id": "quote", "type": "text", "label": "Large Quote", "default": "I love that it makes better health accessible to everyone" },
    { "id": "description", "type": "textarea", "label": "Full Testimonial", "default": "As a professional athlete, I've always looked for ways to stay sharp, feel my best, and fuel my body without overcomplicating it. Laushe uses clean, Sunnah-blessed ingredients that actually deliver. It's about performing at the highest level while staying rooted in tradition." },
    { "id": "name", "type": "text", "label": "Athlete Name", "default": "Arshad Nadeem" },
    { "id": "title", "type": "text", "label": "Athlete Title", "default": "OLYMPIC GOLD MEDALIST, JAVELIN THROW CHAMPION" },
    { "id": "btn_txt", "type": "text", "label": "Button Text", "default": "Shop Laushe Now" },
    { "id": "btn_link", "type": "url", "label": "Button Link" },
    { "id": "disclaimer", "type": "textarea", "label": "Disclaimer Text", "default": "Arshad Nadeem is a proud ambassador and user of Laushe. He trusts our natural formulations for his recovery and peak performance." }
  ],
  "presets": [{ "name": "Athlete endorsement", "category": "Laushe Sections" }]
}
{% endschema %}

<section class="athlete-laushe-section section-padding">
  <div class="container">
    <div class="athlete-luxe-grid">
      <!-- LEFT: IMAGE -->
      <div class="athlete-luxe-img">
        {% if section.settings.image %}
          <img src="{{ section.settings.image | img_url: '1000x' }}" class="luxe-img-fit" alt="{{ section.settings.name }}">
        {% else %}
          <img src="shopify://shop_images/athlete_endorsement.jpg" class="luxe-img-fit" alt="{{ section.settings.name }}">
        {% endif %}
      </div>

      <!-- RIGHT: CONTENT -->
      <div class="athlete-luxe-content">
        <div class="quote-mark-wrap">
          <svg viewBox="0 0 24 24" fill="#004225" opacity="0.1" style="width: 80px; height: 80px;">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-10zm-14 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
        </div>
        
        <h2 class="athlete-luxe-quote">"{{ section.settings.quote }}"</h2>
        <p class="athlete-luxe-body">"{{ section.settings.description }}"</p>
        
        <div class="athlete-luxe-meta">
          <h4 class="meta-name">{{ section.settings.name }}</h4>
          <p class="meta-title">{{ section.settings.title }}</p>
        </div>

        <div class="athlete-luxe-cta">
          <a href="{{ section.settings.btn_link | default: '/collections/all' }}" class="btn-pill btn-forest">
            {{ section.settings.btn_txt }} &nbsp; <span>→</span>
          </a>
        </div>

        <p class="athlete-luxe-disclaimer">{{ section.settings.disclaimer }}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .athlete-luxe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  
  .luxe-img-fit {
    width: 100%;
    height: auto;
    border-radius: 40px;
    display: block;
    box-shadow: 0 40px 100px rgba(0,0,0,0.1);
  }
  
  .athlete-luxe-content {
    position: relative;
    padding-top: 20px;
  }
  
  .quote-mark-wrap {
    position: absolute;
    top: -40px;
    left: -20px;
    z-index: -1;
  }
  
  .athlete-luxe-quote {
    font-size: 56px;
    line-height: 1.1;
    color: #004225;
    font-weight: 800;
    margin-bottom: 40px;
    font-family: 'Poppins', sans-serif;
  }
  
  .athlete-luxe-body {
    font-size: 18px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 40px;
    font-style: normal;
  }
  
  .athlete-luxe-meta {
    margin-bottom: 50px;
  }
  
  .meta-name {
    font-size: 24px;
    font-weight: 800;
    color: #004225;
    margin-bottom: 5px;
  }
  
  .meta-title {
    font-size: 14px;
    color: #D4AF37;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .athlete-luxe-cta {
    margin-bottom: 30px;
  }
  
  .athlete-luxe-disclaimer {
    font-size: 12px;
    color: #999;
    line-height: 1.6;
    font-style: italic;
    max-width: 500px;
  }
  
  @media (max-width: 1024px) {
    .athlete-luxe-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .athlete-luxe-img {
      max-width: 600px;
      margin: 0 auto;
    }
    .athlete-luxe-quote { font-size: 38px; }
    .quote-mark-wrap { top: -20px; left: 0; }
  }
</style>
