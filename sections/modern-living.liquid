{% schema %}
{
  "name": "Modern Living Problem",
  "settings": [
    { "id": "heading", "type": "text", "label": "Heading", "default": "Modern Living Leaves Our Bodies Deficient" },
    { "id": "description", "type": "textarea", "label": "Description", "default": "Laushe is the natural solution that fills the gaps in modern nutrition." },
    { "id": "stat_1_num", "type": "text", "label": "Stat 1 Number", "default": "90%" },
    { "id": "stat_1_txt", "type": "text", "label": "Stat 1 Text", "default": "of adults lack daily essential nutrients." },
    { "id": "stat_2_num", "type": "text", "label": "Stat 2 Number", "default": "61%" },
    { "id": "stat_2_txt", "type": "text", "label": "Stat 2 Text", "default": "experience regular digestive issues." },
    { "id": "btn_txt", "type": "text", "label": "Button Text", "default": "Start Your Journey" },
    { "id": "btn_link", "type": "url", "label": "Button Link" },
    { "id": "side_image", "type": "image_picker", "label": "Side Image" }
  ],
  "presets": [{ "name": "Modern Living Problem", "category": "Laushe Sections" }]
}
{% endschema %}

<section class="modern-living-section section-padding">
  <div class="container">
    <div class="modern-grid">
      <!-- CONTENT -->
      <div class="modern-content">
        <h2 class="modern-heading">{{ section.settings.heading }}</h2>
        <p class="modern-desc">{{ section.settings.description }}</p>
        
        <div class="stats-row-v2">
          <div class="stat-item-v2">
            <span class="stat-num-v2">{{ section.settings.stat_1_num }}</span>
            <span class="stat-txt-v2">{{ section.settings.stat_1_txt }}</span>
          </div>
          <div class="stat-item-v2">
            <span class="stat-num-v2">{{ section.settings.stat_2_num }}</span>
            <span class="stat-txt-v2">{{ section.settings.stat_2_txt }}</span>
          </div>
        </div>

        <div class="cta-wrap" style="margin-top: 40px;">
          <a href="{{ section.settings.btn_link | default: '#' }}" class="btn-pill btn-forest" style="text-decoration: none;">
            {{ section.settings.btn_txt }}
          </a>
        </div>
      </div>

      <!-- IMAGE -->
      <div class="modern-image-wrap">
        {% if section.settings.side_image %}
          <img src="{{ section.settings.side_image | img_url: '1000x' }}" class="modern-img" alt="Health Deficiency">
        {% else %}
          <div class="modern-img placeholder-bg" style="background: #FAFAFA; width:100%; aspect-ratio: 1/1; border-radius: 40px;"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .modern-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 80px;
    align-items: center;
  }
  
  .modern-heading {
    font-size: 56px;
    line-height: 1.1;
    margin-bottom: 25px;
    color: #004225;
    font-weight: 800;
  }
  
  .modern-desc {
    font-size: 18px;
    color: #777;
    margin-bottom: 50px;
    max-width: 500px;
  }
  
  .stats-row-v2 {
    display: flex;
    gap: 40px;
  }
  
  .stat-item-v2 {
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-width: 180px;
  }
  
  .stat-num-v2 {
    font-size: 64px;
    font-weight: 800;
    color: #004225;
    line-height: 1;
  }
  
  .stat-txt-v2 {
    font-size: 14px;
    color: #444;
    line-height: 1.5;
    font-weight: 500;
  }
  
  .modern-img {
    width: 100%;
    height: auto;
    border-radius: 40px;
    display: block;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
  }
  
  @media (max-width: 1024px) {
    .modern-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 50px;
    }
    .modern-content { order: 2; }
    .modern-image-wrap { order: 1; max-width: 500px; margin: 0 auto; }
    .modern-desc { margin: 0 auto 40px; }
    .stats-row-v2 { justify-content: center; }
    .modern-heading { font-size: 40px; }
    .stat-num-v2 { font-size: 48px; }
  }
</style>
