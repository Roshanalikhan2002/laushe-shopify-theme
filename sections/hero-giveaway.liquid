<section class="hero-giveaway">
  <div class="hero-giveaway__container">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="hero-giveaway__link">
    {% endif %}
    
    <div class="hero-giveaway__image-wrapper">
      {% if section.settings.image_desktop != blank %}
        <img src="{{ section.settings.image_desktop | image_url }}" 
             alt="{{ section.settings.image_desktop.alt | escape }}" 
             class="hero-giveaway__image desktop-only" loading="lazy">
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg hero-giveaway__image desktop-only' }}
      {% endif %}

      {% if section.settings.image_mobile != blank %}
        <img src="{{ section.settings.image_mobile | image_url }}" 
             alt="{{ section.settings.image_mobile.alt | escape }}" 
             class="hero-giveaway__image mobile-only" loading="lazy">
      {% endif %}
    </div>

    {% if section.settings.link != blank %}
      </a>
    {% endif %}
  </div>
</section>

<style>
.hero-giveaway {
  width: 100%;
  display: block;
  background-color: #f9f9f9; /* Match background just in case */
}
.hero-giveaway__container {
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
}
.hero-giveaway__image-wrapper {
  width: 100%;
  display: block;
}
.hero-giveaway__image {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
}
.placeholder-svg {
  background-color: #e3e3e3;
  width: 100%;
  height: 400px;
}
.desktop-only {
  display: block;
}
.mobile-only {
  display: none;
}
@media screen and (max-width: 768px) {
  {% if section.settings.image_mobile != blank %}
    .desktop-only {
      display: none;
    }
    .mobile-only {
      display: block;
    }
  {% endif %}
}
</style>

{% schema %}
{
  "name": "Giveaway Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Giveaway Image (Desktop/Default)",
      "info": "Upload your giveaway banner image here."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Giveaway Image (Mobile)",
      "info": "Optional: Upload a different image dimension for mobile devices."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link",
      "info": "Where should users go when they click the banner?"
    }
  ],
  "presets": [
    {
      "name": "Giveaway Hero Banner"
    }
  ]
}
{% endschema %}
