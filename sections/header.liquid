{% schema %}
{
  "name": "Header (Laushe)",
  "settings": [
    {
      "type": "url",
      "id": "shop_all_url",
      "label": "Shop All / Products Page URL",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}

<header class="sticky-header" style="background-color: {{ section.settings.bg_color }};">
  <div class="container header-flex">
    <!-- Hamburger (mobile only) -->
    <div class="menu-toggle" onclick="window.toggleMobileMenu()">
      <ion-icon name="menu-outline"></ion-icon>
    </div>

    <!-- Logo -->
    <div class="logo-emblem" style="flex: 0 0 auto;">
      <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 12px;">
        <img src="{{ 'laushe-logo.jpg' | asset_url }}" alt="Laushe Logo" style="height: 60px; width: auto; object-fit: contain;">
        <div style="display: flex; flex-direction: column; justify-content: center; text-align: left;">
          <span style="font-size: 24px; font-weight: 800; color: #dcb360; font-family: 'Poppins', sans-serif; line-height: 1; letter-spacing: 0.08em; text-transform: uppercase;">Laushe</span>
          <span style="font-size: 11px; font-weight: 600; color: #dcb360; font-family: 'Poppins', sans-serif; letter-spacing: 0.15em; text-transform: uppercase; margin-top: 3px;">by zahra</span>
        </div>
      </a>
    </div>

    <!-- Right Nav (desktop) -->
    <div class="right-nav" style="display: flex; flex: 1; align-items: center; justify-content: flex-end; gap: 30px;">
      <nav class="nav-links" style="display: flex; gap: 15px; align-items: center;">
        
        <a href="/" style="text-decoration: none; color: #004225; font-weight: 700; font-size: 14px; letter-spacing: 0.05em; padding: 10px 15px;">HOME</a>
        
        <!-- COLLECTIONS Dropdown -->
        <div class="nav-dropdown" style="position: relative; display: inline-flex; align-items: center;">
          <button class="nav-dropdown-btn" style="background: none; border: none; cursor: pointer; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 14px; letter-spacing: 0.05em; color: #004225; padding: 10px 15px; display: flex; align-items: center; gap: 5px;">
            COLLECTIONS <span style="font-size: 9px;">&#9660;</span>
          </button>
          <div class="nav-dropdown-menu" style="position: absolute; top: calc(100% + 8px); left: 0; background: white; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.12); min-width: 220px; padding: 10px 0; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s ease; z-index: 2000;">
            
            <a href="{{ section.settings.shop_all_url }}?filter=healthcare" style="display: block; padding: 12px 24px; font-size: 14px; font-weight: 600; color: #333; text-decoration: none;">Healthcare</a>
            
            <a href="{{ section.settings.shop_all_url }}?filter=organic" style="display: block; padding: 12px 24px; font-size: 14px; font-weight: 600; color: #333; text-decoration: none;">Organic Products</a>
            
          </div>
        </div>

        <a href="/pages/contact" style="text-decoration: none; color: #004225; font-weight: 700; font-size: 14px; letter-spacing: 0.05em; padding: 10px 15px;">CONTACT</a>
        
      </nav>

      <div class="header-icons nav-links" style="display: flex; gap: 20px; align-items: center;">
        <a href="javascript:void(0)" onclick="toggleSearchBar()"><ion-icon name="search-outline" style="font-size: 20px; color: #004225;"></ion-icon></a>
        <a href="/cart" class="header-cart-link" onclick="event.preventDefault(); LausheCart.open();" style="position: relative;">
          <ion-icon name="bag-handle-outline" style="font-size: 20px; color: #004225;"></ion-icon>
          <span class="header-cart-count {% if cart.item_count == 0 %}hidden{% endif %}" style="position: absolute; top: -5px; right: -5px; background: #004225; color: white; font-size: 10px; padding: 2px 5px; border-radius: 50%; min-width: 16px; height: 16px; display: {% if cart.item_count > 0 %}flex{% else %}none{% endif %}; align-items: center; justify-content: center;">
            {{ cart.item_count }}
          </span>
        </a>
      </div>
    </div>
  </div>
  
  <!-- SEARCH BAR OVERLAY -->
  <div id="search-bar">
    <form action="/search" method="get" role="search" style="width: 100%; max-width: 600px; display: flex; position: relative; margin: 0 auto;">
        <input type="hidden" name="type" value="product">
        <input type="search" name="q" placeholder="Search our store..." value="{{ search.terms | escape }}" />
        <button type="submit" style="position: absolute; right: 20px; top: 18px; background: none; border: none; cursor: pointer;">
            <ion-icon name="search-outline" style="font-size: 24px; color: #004225;"></ion-icon>
        </button>
    </form>
  </div>
</header>

<!-- MOBILE NAVIGATION DRAWER -->
<div id="mobile-drawer-overlay" class="mobile-drawer-overlay" onclick="window.toggleMobileMenu()"></div>
<div id="mobile-drawer" class="mobile-drawer">
  <div class="mobile-drawer-header">
    <div class="mobile-drawer-close" onclick="window.toggleMobileMenu()">&times;</div>
    <div class="mobile-drawer-logo" style="text-align: center;">
      <a href="/">
        <img src="{{ 'laushe-logo.jpg' | asset_url }}" alt="Laushe Logo" style="height: 70px; width: auto; object-fit: contain; margin-bottom: 20px;">
      </a>
    </div>
  </div>
  <nav class="mobile-drawer-nav">
    <a href="/" onclick="window.toggleMobileMenu()">HOME</a>
    <a href="{{ section.settings.shop_all_url }}?filter=healthcare" onclick="window.toggleMobileMenu()">HEALTHCARE</a>
    <a href="{{ section.settings.shop_all_url }}?filter=organic" onclick="window.toggleMobileMenu()">ORGANIC PRODUCTS</a>
    <a href="/pages/contact" onclick="window.toggleMobileMenu()">CONTACT US</a>
  </nav>
</div>

<script>
  // Dropdown hover logic
  document.querySelectorAll('.nav-dropdown').forEach(function(el) {
    el.addEventListener('mouseenter', function() {
      const menu = el.querySelector('.nav-dropdown-menu');
      if(menu) {
        menu.style.opacity = '1';
        menu.style.visibility = 'visible';
        menu.style.transform = 'translateY(0)';
      }
    });
    el.addEventListener('mouseleave', function() {
      const menu = el.querySelector('.nav-dropdown-menu');
      if(menu) {
        menu.style.opacity = '0';
        menu.style.visibility = 'hidden';
        menu.style.transform = 'translateY(-8px)';
      }
    });
  });

  // Mobile Drawer
  function toggleMobileMenu() {
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('mobile-drawer-overlay');
    if(drawer && overlay) {
      drawer.classList.toggle('open');
      overlay.classList.toggle('active');
      document.body.style.overflow = drawer.classList.contains('open') ? 'hidden' : '';
    }
  }
  // Update cart count AJAX
  document.addEventListener('cart:updated', function() {
    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        const counts = document.querySelectorAll('.header-cart-count');
        counts.forEach(el => {
          el.textContent = cart.item_count;
          if (cart.item_count > 0) {
            el.style.display = 'flex';
          } else {
            el.style.display = 'none';
          }
        });
      })
      .catch(err => console.error('Error fetching cart:', err));
  });

  // Search Bar Toggle Logic
  function toggleSearchBar() {
    const searchBar = document.getElementById('search-bar');
    if (searchBar) {
      searchBar.classList.toggle('active');
      if (searchBar.classList.contains('active')) {
        searchBar.querySelector('input[type="search"]').focus();
      }
    }
  }

  // Close search when clicking outside
  document.addEventListener('click', function(e) {
    const searchBar = document.getElementById('search-bar');
    const searchIcon = document.querySelector('[onclick="toggleSearchBar()"]');
    if (searchBar && searchBar.classList.contains('active')) {
      if (!searchBar.contains(e.target) && !searchIcon.contains(e.target)) {
        searchBar.classList.remove('active');
      }
    }
  });

  window.toggleMobileMenu = toggleMobileMenu;
  window.toggleSearchBar = toggleSearchBar;
</script>
