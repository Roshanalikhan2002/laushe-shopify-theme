{% comment %}
  Custom Product Template for Liquid Blush
  Inspired by Skindeep design
{% endcomment %}

<style>
    :root {
        --olive-bg: #FFFFFF;
        --olive-inner: #FFFFFF;
        --cream-bg: #f9f9f1;
        --dark-green: #1a2e22;
        --accent-green: #09655D;
        --text-gray: #666666;
        --star-gold: #e79d3d;
        --sticky-h: 84px;
    }

    .laushe-product-container {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
        font-family: 'Outfit', sans-serif;
        background-color: var(--cream-bg);
        color: var(--dark-green);
        width: 100%;
        overflow-x: hidden;
    }

    /* Full Width Container */
    .product-section {
        display: flex;
        width: 100%;
        min-height: 100vh;
    }

    /* Left Visuals (50%) */
    .left-visuals {
        width: 50%;
        background-color: var(--olive-bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2vw;
        position: sticky;
        top: 0;
        height: 100vh;
    }

    .hero-box {
        width: 90%;
        height: 85%;
        background: var(--olive-inner);
        border-radius: 15px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .main-img-container {
        width: 100%;
        height: 85%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-img-container img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transform: scale(1.2);
        filter: drop-shadow(0 40px 80px rgba(0,0,0,0.12));
    }

    /* Thumbnail Carousel */
    .thumb-nav {
        position: relative;
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .thumb-btn {
        background: rgba(255,255,255,0.9);
        border: 0;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .thumb-list {
        display: flex;
        gap: 10px;
        overflow: hidden;
    }

    .thumb-node {
        width: clamp(60px, 5.5vw, 90px);
        height: clamp(60px, 5.5vw, 90px);
        border-radius: 50%;
        border: 4px solid white;
        background-size: cover;
        background-position: center;
        cursor: pointer;
        position: relative;
        transition: 0.3s;
        background-color: #eee; /* Placeholder bg */
    }

    .thumb-node.active { border-color: var(--dark-green); transform: scale(1.1); }
    .thumb-node.has-video::after {
        content: '▶';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 18px;
        text-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }

    /* Right Content (50%) */
    .right-content {
        width: 50%;
        background-color: var(--cream-bg);
        padding: clamp(40px, 5vw, 100px) clamp(30px, 6vw, 120px);
        display: flex;
        flex-direction: column;
    }

    .prod-title {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(34px, 3.5vw, 65px);
        font-weight: 800;
        color: var(--dark-green);
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .prod-rating {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 25px;
        color: var(--star-gold);
        font-size: clamp(16px, 1.3vw, 22px);
    }

    .prod-rating span { color: #435247; font-weight: 600; }

    .prod-price {
        display: flex;
        align-items: baseline;
        gap: 20px;
        margin-bottom: 35px;
    }

    .price-was { font-size: clamp(18px, 1.5vw, 24px); color: #8b9086; text-decoration: line-through; font-weight: 500; }
    .price-is { font-size: clamp(38px, 3.5vw, 65px); font-weight: 800; color: #2f442f; }

    .prod-badges {
        display: flex;
        gap: 30px;
        padding: 25px 0;
        border-top: 1px solid rgba(0,0,0,0.08);
        margin-bottom: 25px;
    }

    .badge-node {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: clamp(13px, 1.1vw, 18px);
        font-weight: 700;
        color: var(--dark-green);
    }

    /* Tabs Section */
    .tabs-nav {
        display: flex;
        gap: 30px;
        border-bottom: 1.5px solid #d2d0b8;
        margin-bottom: 25px;
    }

    .tab-node {
        padding: 12px 0;
        font-size: clamp(14px, 1.2vw, 20px);
        font-weight: 700;
        color: #8a918c;
        cursor: pointer;
        position: relative;
        background: none;
        border: 0;
        font-family: inherit;
    }

    .tab-node.active { color: var(--dark-green); }
    .tab-node.active::after {
        content: '';
        position: absolute;
        bottom: -1.5px;
        left: 0;
        width: 100%;
        height: 3px;
        background: var(--dark-green);
    }

    .tab-content {
        font-size: clamp(16px, 1.3vw, 20px);
        line-height: 1.7;
        color: #435247;
        margin-bottom: 40px;
        min-height: 80px;
    }

    /* Videos Section */
    .video-header { font-size: clamp(16px, 1.3vw, 22px); font-weight: 800; margin-bottom: 15px; }
    .video-scroll-wrap {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 40px;
    }
    .video-container {
        display: flex;
        gap: 15px;
        overflow-x: auto;
        padding-bottom: 15px;
        scrollbar-width: thin;
        scrollbar-color: #c9c7b1 transparent;
    }
    .video-item {
        min-width: clamp(200px, 18vw, 300px);
        aspect-ratio: 3/4.8;
        border-radius: 15px;
        overflow: hidden;
        background: #e0ddd0;
        border: 1px solid rgba(0,0,0,0.05);
    }
    .video-item img { width: 100%; height: 100%; object-fit: cover; }

    /* Swatches Section */
    .swatch-header { font-size: clamp(15px, 1.2vw, 19px); font-weight: 700; margin-bottom: 15px; }
    .swatch-list { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 50px; }
    .swatch-node {
        width: clamp(38px, 3.2vw, 50px);
        height: clamp(38px, 3.2vw, 50px);
        border-radius: 50%;
        border: 2px solid #ccc;
        cursor: pointer;
        transition: 0.2s;
    }
    .swatch-node.active {
        border: 2px solid var(--dark-green);
        box-shadow: 0 0 0 2px var(--cream-bg), 0 0 0 4px var(--dark-green);
        transform: scale(1.1);
    }

    /* Desktop Sticky Bar Removed */
    .sticky-footer { display: none; }

    .footer-left { display: flex; align-items: center; gap: 15px; }
    .footer-left img { width: 55px; height: 55px; background: #f5f5f0; border-radius: 8px; object-fit: contain; }
    .footer-info { display: flex; flex-direction: column; }
    .footer-title { font-weight: 800; font-size: 14px; }
    .footer-stars { color: var(--star-gold); font-size: 12px; }

    .footer-right { display: flex; align-items: center; gap: 25px; }
    .qty-box {
        display: flex;
        align-items: center;
        border: 1px solid #b8c4bb;
        border-radius: 999px;
        padding: 8px 18px;
        gap: 15px;
        background: #fafaf8;
    }
    .qty-box button { background: 0; border: 0; font-size: 22px; cursor: pointer; color: var(--dark-green); }
    .qty-box span { font-weight: 700; min-width: 20px; text-align: center; }

    .footer-price { font-weight: 800; font-size: 18px; }
    .footer-atc {
        background: var(--dark-green);
        color: white;
        border: 0;
        border-radius: 999px;
        height: 50px;
        padding: 0 40px;
        font-weight: 800;
        font-size: 13px;
        cursor: pointer;
        letter-spacing: 0.5px;
    }

    /* Floating UI */
    .f-cart { position: fixed; right: 25px; top: 50%; transform: translateY(-50%); width: 56px; height: 56px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 25px rgba(0,0,0,0.12); z-index: 3100; cursor: pointer; font-size: 22px; }
    .f-chat { position: fixed; right: 25px; bottom: 105px; background: var(--dark-green); color: white; border-radius: 999px; padding: 12px 20px; font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 8px; z-index: 3100; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }

    /* Badges Section */
    .badges-section {
        background-color: #f5f5ea;
        background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');
        padding: clamp(40px, 5vw, 80px) 2vw;
        width: 100%;
        text-align: center;
        border-top: 1px solid rgba(0,0,0,0.03);
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }

    .badges-row {
        display: flex;
        justify-content: center;
        gap: clamp(20px, 4vw, 80px);
        max-width: 1400px;
        margin: 0 auto;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }
    .badges-row::-webkit-scrollbar { display: none; }

    .badge-card {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        scroll-snap-align: center;
        min-width: 150px;
    }

    .badge-icon {
        width: clamp(70px, 6vw, 100px);
        height: clamp(70px, 6vw, 100px);
        border: 2px solid var(--dark-green);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        position: relative;
    }

    .badge-icon svg { width: 100%; height: 100%; color: var(--dark-green); }

    .badge-label {
        font-size: clamp(13px, 1.1vw, 18px);
        font-weight: 700;
        color: var(--dark-green);
        white-space: nowrap;
    }

    /* Pagination Dots (Mobile Only) */
    .badge-dots {
        display: none;
        justify-content: center;
        gap: 8px;
        margin-top: 25px;
    }

    .dot {
        width: 6px;
        height: 6px;
        background: #bbb;
        border-radius: 50%;
        transition: 0.3s;
    }
    .dot.active { background: var(--dark-green); width: 12px; border-radius: 4px; }

    /* Feature Section: Text with Image */
    .feature-section {
        display: flex;
        width: 100%;
        min-height: 80vh;
        background-color: #40ad8b;
    }

    .feature-text {
        width: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5vw;
        color: white;
        text-align: left;
    }

    .feature-text h2 {
        font-size: clamp(40px, 5.5vw, 90px);
        font-weight: 800;
        line-height: 1.1;
        max-width: 12ch;
        letter-spacing: -0.03em;
    }

    .feature-image {
        width: 50%;
        overflow: hidden;
        background-color: #eee; /* Placeholder */
    }

    .feature-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Reinvented Section */
    .reinvented-section {
        background-color: #f5f5ea;
        background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');
        padding: clamp(60px, 8vw, 120px) 5vw;
        text-align: center;
    }

    .reinvented-section h2 {
        font-size: clamp(32px, 4vw, 70px);
        font-weight: 800;
        margin-bottom: clamp(40px, 6vw, 80px);
        color: var(--dark-green);
    }

    .reinvented-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr 1fr;
        align-items: center;
        gap: 40px;
        max-width: 1600px;
        margin: 0 auto;
    }

    .features-col {
        display: flex;
        flex-direction: column;
        gap: clamp(30px, 4vw, 60px);
    }

    .feature-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        text-align: center;
    }

    .feat-icon {
        width: 40px;
        height: 40px;
        border: 1.5px solid var(--dark-green);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dark-green);
        margin-bottom: 5px;
    }

    .feat-title { font-size: clamp(16px, 1.3vw, 24px); font-weight: 800; color: #3a4a3e; }
    .feat-desc { font-size: clamp(14px, 1.1vw, 18px); color: #6a7a6e; line-height: 1.5; max-width: 30ch; }

    .center-group-img {
        background-color: transparent;
    }
    .center-group-img img {
        width: 100%;
        max-width: 600px;
        filter: drop-shadow(0 30px 60px rgba(0,0,0,0.1));
    }

    /* Reviews Section */
    .reviews-section {
        background-color: #f5f5ea;
        padding: clamp(60px, 8vw, 100px) 5vw;
    }

    .reviews-header {
        max-width: 1400px;
        margin: 0 auto 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1.5px solid #d2d0b8;
        padding-bottom: 25px;
    }

    .header-stats { display: flex; align-items: center; gap: 15px; }
    .header-stars { color: var(--star-gold); font-size: 24px; }
    .header-count { font-weight: 700; font-size: 18px; color: var(--dark-green); }

    .write-review { font-weight: 700; font-size: 16px; color: var(--dark-green); text-decoration: underline; cursor: pointer; }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .review-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .rev-user { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 18px; }
    .rev-verified { color: #1da1f2; font-size: 14px; }
    .rev-date { font-size: 14px; color: #999; margin-bottom: 5px; }
    .rev-stars { color: var(--star-gold); font-size: 18px; }
    .rev-text { font-size: 16px; line-height: 1.6; color: #435247; }
    .rev-item { font-size: 14px; color: #666; font-weight: 600; margin-top: 10px; }
    .rev-img { width: 100%; max-width: 150px; border-radius: 8px; margin-top: 15px; object-fit: cover; }

    /* ATC Bar */
    .mobile-buy-bar {
        display: flex;
        margin-top: 30px;
        gap: 15px;
        align-items: center;
    }

    .m-qty {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid #b8c4bb;
        border-radius: 999px;
        height: 56px;
        padding: 0 15px;
        min-width: 110px;
        background: #fafaf8;
    }
    .m-qty button { background: 0; border: 0; font-size: 20px; color: var(--dark-green); cursor: pointer; }
    .m-qty span { font-weight: 700; font-size: 16px; }

    .m-atc {
        flex: 1;
        background: var(--dark-green);
        color: white;
        border: 0;
        border-radius: 999px;
        height: 56px;
        font-weight: 800;
        font-size: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        cursor: pointer;
    }

    /* Mobile Sticky Bar */
    .mobile-footer {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: white;
        padding: 12px 20px;
        box-shadow: 0 -10px 30px rgba(0,0,0,0.1);
        z-index: 4000;
        align-items: center;
        justify-content: space-between;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .product-section { flex-direction: column; }
        .left-visuals, .right-content { width: 100%; height: auto; position: relative; padding: 40px 20px; }
        .left-visuals { padding: 0 !important; padding-bottom: 60px !important; }
        .hero-box { width: 100%; border-radius: 0; background: white; height: auto; aspect-ratio: 1/1; }
        .thumb-nav { margin-top: 50px !important; }
        .sticky-footer, .f-cart, .f-chat, .mobile-footer { display: none !important; }
        .mobile-buy-bar { display: flex; }
        .feature-section { flex-direction: column; }
        .feature-text, .feature-image { width: 100%; height: auto; }
        .feature-text { padding: 60px 30px; text-align: center; }
        .feature-image { height: 50vh; }
        .reinvented-grid { grid-template-columns: 1fr; gap: 50px; }
        .features-col.left-col { order: 1; }
        .center-group-img { order: 2; }
        .features-col.right-col { order: 3; }
        .reviews-grid { grid-template-columns: 1fr; }
        .reviews-header { flex-direction: column; gap: 20px; align-items: flex-start; }
        .badges-row { justify-content: flex-start; padding: 0 20px; }
        .badge-card { min-width: 100%; }
        .badge-dots { display: flex; }
    }
</style>

<div class="laushe-product-container">
    <main class="product-section">
        <!-- Visuals (Left) -->
        <section class="left-visuals">
            <div class="hero-box">
                <div class="main-img-container">
                    <img src="" id="mainImg" alt="Product Image Placeholder">
                </div>
                <div class="thumb-nav">
                    <button class="thumb-btn">‹</button>
                    <div class="thumb-list" id="thumbList">
                        <!-- Thumbs will be here -->
                    </div>
                    <button class="thumb-btn">›</button>
                </div>
            </div>
        </section>

        <!-- Details (Right) -->
        <section class="right-content">
            <h1 class="prod-title">{{ product.title | default: "Liquid Blush" }}</h1>
            <div class="prod-subtitle">Dewy • Lightweight • Buildable</div>
            
            <div class="prod-price">
                <span class="price-was">{{ product.compare_at_price | default: 189000 | money }}</span>
                <span class="price-is">{{ product.price | default: 129000 | money }}</span>
            </div>

            <div class="prod-badges">
                <div class="badge-node">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg>
                    Premium Quality Ingredients
                </div>
                <div class="badge-node">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 8l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                    Ships All Over Pakistan
                </div>
            </div>

            <!-- Tabs Section -->
            <nav class="tabs-nav">
                <button class="tab-node active" data-tab="details">Details</button>
                <button class="tab-node" data-tab="works">How it Works</button>
                <button class="tab-node" data-tab="use">How To Use</button>
                <button class="tab-node" data-tab="ing">Ingredients</button>
            </nav>
            <div class="tab-content" id="tabText">
                Liquid Blush is your everyday juicy cheek obsession. It delivers a natural flush with the comfort and care of skincare—no stickiness, no heavy feel. Just soft, pop-worthy cheeks that look as good as they feel.
            </div>

            <!-- Video Section -->
            {% comment %}
            <div class="video-scroll-wrap">
                <div class="video-header">See it in action</div>
                <div class="video-container">
                    <div class="video-item"><img src="" alt="Video Placeholder 1"></div>
                    <div class="video-item"><img src="" alt="Video Placeholder 2"></div>
                    <div class="video-item"><img src="" alt="Video Placeholder 3"></div>
                </div>
            </div>
            {% endcomment %}
            <!-- Swatches Section -->
            <div class="swatch-header">Color: <span id="colorName" style="font-weight: 500;">Select Shade</span></div>
            <div class="swatch-list">
                {% for variant in product.variants %}
                    <div class="swatch-node" 
                         style="background: {{ variant.metafields.custom.color_hex | default: '#ccc' }};"
                         data-variant-id="{{ variant.id }}"
                         data-variant-name="{{ variant.title }}"
                         data-variant-img="{{ variant.image | img_url: 'master' }}">
                    </div>
                {% endfor %}
            </div>

            <!-- ATC Bar (Desktop & Mobile) -->
            <div class="mobile-buy-bar">
                <div class="m-qty">
                    <button onclick="changeQty(-1)">−</button>
                    <span id="qtyVal">1</span>
                    <button onclick="changeQty(1)">+</button>
                </div>
                <button class="m-atc" onclick="addToCart()">Add to cart <span style="font-size: 18px;">→</span></button>
            </div>
        </section>
{% comment %}
        ATC Bar Moved here
{% endcomment %}

    </main>

    <!-- Badges Section -->
    <section class="badges-section">
        <div class="badges-row" id="badgeSlider">
            <div class="badge-card">
                <div class="badge-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 5a2 2 0 1 1 4 0c.5 0 2.5 2.5 2.5 4.5s-1.5 4-2.5 4-1-.5-1-1.5c-1 1-1.5 1.5-2.5 1.5s-2.5-2-2.5-4 2-4.5 2.5-4.5Z"/><path d="M12 14c-1 0-2 .5-2 1.5s1 2.5 2 2.5 2-1.5 2-2.5-1-1.5-2-1.5Z"/><line x1="4" y1="4" x2="20" y2="20"/></svg>
                </div>
                <div class="badge-label">Cruelty free</div>
            </div>
            <div class="badge-card">
                <div class="badge-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/><line x1="4" y1="4" x2="20" y2="20"/></svg>
                </div>
                <div class="badge-label">Mineral Oil Free</div>
            </div>
            <div class="badge-card">
                <div class="badge-icon">
