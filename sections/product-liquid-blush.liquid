<script>
    const tabData = {
        'details': 'A silky, lightweight liquid blush designed to add a fresh, natural flush to the cheeks. The blendable formula melts seamlessly into the skin, delivering a soft radiant glow that looks effortlessly natural. (15 ml ℮ / 0.50 fl oz)',
        'works': 'Key Benefits:\n• Natural radiant flush\n• Lightweight & blendable formula\n• Buildable color payoff\n• Long-lasting wear\n• Smooth, seamless finish\n• Suitable for all skin types',
        'use': 'Apply 1–2 small dots on the cheeks and blend using fingertips, brush, or sponge. Layer to build desired intensity.',
        'ing': 'Hero Ingredients:\nHyaluronic Acid – Helps maintain skin hydration\nVitamin E – Antioxidant protection\nRose Extract – Helps refresh and soften skin\nGlycerin – Supports skin moisture balance'
    };

    // Pull real variant IDs from Shopify
    const allVariants = {
        {% for variant in product.variants %}
            "{{ variant.title }}": {{ variant.id }},
        {% endfor %}
    };

    // Use the first variant ID from Shopify as a default
    let selectedVariantId = {{ product.variants[0].id | default: 0 }};

    // 1. Tab Logic
    document.querySelectorAll('.tab-node').forEach(btn => {
        btn.onclick = () => {
            document.querySelectorAll('.tab-node').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('tabText').innerText = tabData[btn.dataset.tab];
        };
    });

    // 2. Swatch & Image Logic
    const variantImages = {
        'Liquid Blush': [
            "{{ 'liquid-blush-petal-1-texture.jpg' | asset_url }}",
            "{{ 'liquid-blush-petal-1.jpg' | asset_url }}"
        ],
        'Soft Liquid Blush': [
            "{{ 'soft-bloom-liquid-blush-2.jpg' | asset_url }}",
            "{{ 'soft-petal-blush-2-texture.jpg' | asset_url }}"
        ]
    };

    function updateProductUI(colorName) {
        const images = variantImages[colorName] || variantImages['Liquid Blush'];
        
        // Update the selected variant ID based on the color name
        if (allVariants[colorName]) {
            selectedVariantId = allVariants[colorName];
            console.log("Selected Variant ID updated to:", selectedVariantId);
        }
        
        // Update main image
        const mainImg = document.getElementById('mainImg');
        if (mainImg) mainImg.src = images[0];
        
        const footerImg = document.getElementById('footerImg');
        if (footerImg) footerImg.src = images[0];
        
        const mobileImg = document.getElementById('mobileImg');
        if (mobileImg) mobileImg.src = images[0];
        
        // Render exactly 2 thumbnails
        renderThumbs(images);
        
        // Update color name text
        const colorNameEl = document.getElementById('colorName');
        if (colorNameEl) colorNameEl.innerText = colorName;
    }

    // 3. Thumbnails (Limited to 2)
    function renderThumbs(images) {
        const list = document.getElementById('thumbList');
        if(!list) return;
        list.innerHTML = '';
        
        // Take only the first 2 images
        const thumbsToShow = images.slice(0, 2);

        thumbsToShow.forEach((t, i) => {
            if(!t || t.includes('no-image')) return;
            const node = document.createElement('div');
            node.className = 'thumb-node' + (i === 0 ? ' active' : '');
            node.style.backgroundImage = `url('${t}')`;
            node.onclick = () => {
                document.getElementById('mainImg').src = t;
                document.querySelectorAll('.thumb-node').forEach(tn => tn.classList.remove('active'));
                node.classList.add('active');
            };
            list.appendChild(node);
        });
    }

    // Initial Load
    updateProductUI('Liquid Blush');

    // Handle Swatch Clicks (Manual injection for now)
    const swatchList = document.querySelector('.swatch-list');
    swatchList.innerHTML = `
        <div class="swatch-node active" style="background: #c83233;" onclick="updateProductUI('Liquid Blush'); this.parentElement.querySelectorAll('.swatch-node').forEach(s=>s.classList.remove('active')); this.classList.add('active');"></div>
        <div class="swatch-node" style="background: #ff7b94;" onclick="updateProductUI('Soft Liquid Blush'); this.parentElement.querySelectorAll('.swatch-node').forEach(s=>s.classList.remove('active')); this.classList.add('active');"></div>
    `;

    // 4. Quantity
    function changeQty(v) {
        const span = document.getElementById('qtyVal');
        const mSpan = document.getElementById('mQtyVal');
        let n = parseInt(span.innerText);
        n = Math.max(1, n + v);
        span.innerText = n;
        if (mSpan) mSpan.innerText = n;
    }

    // 5. Add to Cart (Integrate with LausheCart Drawer)
    function addToCart() {
        const qtyVal = document.getElementById('qtyVal');
        const mQtyVal = document.getElementById('mQtyVal');
        const qty = parseInt(qtyVal ? qtyVal.innerText : (mQtyVal ? mQtyVal.innerText : 1));
        
        if (!selectedVariantId || selectedVariantId === 0) {
            alert("Error: No Variant ID found. Please check Shopify Admin.");
            return;
        }

        let formData = {
            'items': [{
                'id': parseInt(selectedVariantId),
                'quantity': qty
            }]
        };

        fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
            if(data.status && data.status === 'error') {
                alert('Shopify Error: ' + data.description);
                return;
            }
            
            // Trigger the cart drawer after a short delay
            setTimeout(() => {
                if(window.LausheCart) {
                    window.LausheCart.open();
                } else {
                    window.location.href = '/cart';
                }
            }, 300);
        })
        .catch((error) => {
            console.error('Fetch Error:', error);
            alert('Something went wrong. Please try again.');
        });
    }

    // 6. Badge Slider Observer
    const slider = document.getElementById('badgeSlider');
    const dots = document.querySelectorAll('#badgeDots .dot');
    const cards = document.querySelectorAll('.badge-card');

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const index = Array.from(cards).indexOf(entry.target);
                dots.forEach(d => d.classList.remove('active'));
                if (dots[index]) dots[index].classList.add('active');
            }
        });
    }, { root: slider, threshold: 0.6 });

    cards.forEach(card => observer.observe(card));
</script>

