{% schema %}
{
  "name": "Our Story (Laushe)",
  "settings": [
    { "id": "bg_color", "type": "color", "label": "Background Color", "default": "#FAF7F2" },
    { "id": "subtitle", "type": "text", "label": "Subtitle", "default": "OUR STORY" },
    { "id": "title", "type": "text", "label": "Title", "default": "Rooted in Tradition, Crafted with Love" },
    { "id": "description_1", "type": "textarea", "label": "Description Paragraph 1", "default": "Laushe was born from a simple belief: that the best health solutions come from nature itself." },
    { "id": "description_2", "type": "textarea", "label": "Description Paragraph 2", "default": "We source our ingredients directly from trusted farms, ensuring every product meets the highest standards." },
    { "id": "image", "type": "image_picker", "label": "Story Image" },
    { "id": "badge_text", "type": "text", "label": "Badge Text", "default": "Est. 2024" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Story Stat",
      "limit": 3,
      "settings": [
        { "id": "number", "type": "text", "label": "Stat Number", "default": "100%" },
        { "id": "label", "type": "text", "label": "Stat Label", "default": "Natural" }
      ]
    }
  ],
  "presets": [{ "name": "Our Story (Laushe)", "category": "Laushe Sections" }]
}
{% endschema %}

<section id="laushe-story" class="story-laushe-v2" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="story-grid-v2">
      <!-- LEFT CONTENT -->
      <div class="story-left">
        <span class="story-label-v2">{{ section.settings.subtitle }}</span>
        <h2 class="story-title-v2">{{ section.settings.title }}</h2>
        
        <div class="story-paragraphs">
          <p class="story-p-v2">{{ section.settings.description_1 }}</p>
          <p class="story-p-v2">{{ section.settings.description_2 }}</p>
        </div>

        <div class="story-stats-row-v2">
          {% for block in section.blocks %}
            <div class="story-stat-v2" {{ block.shopify_attributes }}>
              <span class="stat-large-v2">{{ block.settings.number }}</span>
              <span class="stat-small-v2">{{ block.settings.label }}</span>
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- RIGHT IMAGE -->
      <div class="story-right">
        <div class="story-img-wrapper">
          {% if section.settings.image %}
            <img src="{{ section.settings.image | img_url: '1000x' }}" class="story-img-v2" alt="Our Story">
          {% else %}
            <img src="shopify://shop_images/story_lifestyle.jpg" class="story-img-v2" alt="Our Story">
          {% endif %}
          
          <div class="story-float-badge">
            {{ section.settings.badge_text }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .story-laushe-v2 {
    padding: 120px 0;
  }
  
  .story-grid-v2 {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 100px;
    align-items: center;
  }
  
  .story-label-v2 {
    color: #D4AF37;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 25px;
    display: block;
  }
  
  .story-title-v2 {
    font-size: 52px;
    color: #004225;
    margin-bottom: 40px;
    line-height: 1.1;
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  
  .story-paragraphs {
    margin-bottom: 50px;
  }
  
  .story-p-v2 {
    font-size: 16px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 25px;
    max-width: 520px;
  }
  
  .story-stats-row-v2 {
    display: flex;
    gap: 60px;
    border-top: 1px solid rgba(0, 66, 37, 0.08);
    padding-top: 40px;
  }
  
  .story-stat-v2 {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .stat-large-v2 {
    font-size: 36px;
    font-weight: 800;
    color: #004225;
    line-height: 1;
  }
  
  .stat-small-v2 {
    font-size: 14px;
    color: #888;
    font-weight: 600;
  }
  
  .story-img-wrapper {
    position: relative;
    padding-bottom: 20px;
  }
  
  .story-img-v2 {
    width: 100%;
    height: auto;
    border-radius: 40px;
    display: block;
    box-shadow: 0 40px 100px rgba(0,0,0,0.1);
  }
  
  .story-float-badge {
    position: absolute;
    bottom: 40px;
    left: -30px;
    background: #D4AF37;
    color: white;
    padding: 12px 28px;
    border-radius: 12px;
    font-weight: 800;
    font-size: 15px;
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.4);
    z-index: 2;
  }
  
  @media (max-width: 1100px) {
    .story-grid-v2 {
      grid-template-columns: 1fr;
      gap: 60px;
      text-align: center;
    }
    .story-right { order: 1; max-width: 600px; margin: 0 auto; }
    .story-left { order: 2; }
    .story-p-v2 { margin: 0 auto 25px; }
    .story-stats-row-v2 { justify-content: center; }
    .story-float-badge { left: 20px; bottom: 20px; }
    .story-title-v2 { font-size: 38px; }
  }
</style>
