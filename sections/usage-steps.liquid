{% schema %}
{
  "name": "Usage Steps",
  "presets": [{ "name": "Usage Steps", "category": "Luxe Funnel" }]
}
{% endschema %}

<section class="section-padding bg-soft-mint" style="background: #E8F3ED; padding: 120px 0;">
  <div class="container-wide text-center" style="max-width: 1280px; margin: 0 auto; text-align: center;">
    <h2 class="h1" style="font-size: 48px; font-weight: 800; margin-bottom: 60px;">Delicious, Herbal Formula</h2>
    <div class="steps-grid">
      <div class="step-card">
         <div class="step-num">1</div>
         <p style="font-size: 16px; line-height: 1.6;">Each box contains <strong>30 sachets</strong> for a full month supply.</p>
      </div>
      <div class="step-card">
         <div class="step-num">2</div>
         <p style="font-size: 16px; line-height: 1.6;">Take <strong>1 sachet</strong> after each main meal (3 times per day).</p>
      </div>
      <div class="step-card">
         <div class="step-num">3</div>
         <p style="font-size: 16px; line-height: 1.6;">Use daily for <strong>3 months</strong> for visible transformation.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .step-card { background: #FFF; padding: 50px 40px; border-radius: 30px; box-shadow: 0 15px 40px rgba(0,0,0,0.05); }
  .step-num { background: #1B4332; color: #D4AF37; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px; font-weight: 800; font-size: 20px; }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }
</style>
