<section class="video-grid-wrapper section-padding" style="background-color: {{ section.settings.bg_color }};" id="section-{{ section.id }}">
  <div class="container">
    
    {% if section.settings.heading != blank %}
      <div class="section-header text-center" style="margin-bottom: 40px;">
        <h2 style="color: #004225; font-weight: 800;">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="video-grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="video-thumb-item" {{ block.shopify_attributes }}>
            <div class="video-thumb-inner">
              {% if block.settings.thumbnail != blank %}
                <img src="{{ block.settings.thumbnail | img_url: '600x800', crop: 'center' }}" alt="Video Thumbnail" class="video-preview-img">
              {% else %}
                <div class="video-placeholder"></div>
              {% endif %}
              
              <div class="video-play-overlay">
                <span class="play-icon">▶</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..5) %}
          <div class="video-thumb-item">
            <div class="video-thumb-inner">
              <div class="video-placeholder"></div>
              <div class="video-play-overlay">
                <span class="play-icon">▶</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }} .video-grid-wrapper { padding: 100px 0; }
  #section-{{ section.id }} .video-grid { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }
  #section-{{ section.id }} .video-thumb-item { flex: 1; min-width: 180px; max-width: 240px; aspect-ratio: 9/12; }
  #section-{{ section.id }} .video-thumb-inner { width: 100%; height: 100%; background: #E0E0E0; border-radius: 20px; position: relative; overflow: hidden; cursor: pointer; transition: transform 0.3s ease; }
  #section-{{ section.id }} .video-thumb-inner:hover { transform: scale(1.02); }
  #section-{{ section.id }} .video-placeholder { width: 100%; height: 100%; background: #E0E0E0; }
  #section-{{ section.id }} .video-preview-img { width: 100%; height: 100%; object-fit: cover; }
  #section-{{ section.id }} .video-play-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; pointer-events: none; z-index: 2; }
  #section-{{ section.id }} .play-icon { font-size: 48px; color: white; opacity: 0.9; }
</style>

{% schema %}
{
  "name": "Social Video Grid (Laushe)",
  "settings": [
    { "id": "heading", "type": "text", "label": "Heading", "default": "" },
    { "id": "bg_color", "type": "color", "label": "Background Color", "default": "#FAFAFA" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video Item",
      "settings": [
        { "id": "thumbnail", "type": "image_picker", "label": "Thumbnail" },
        { "id": "video_url", "type": "url", "label": "Video Link (Optional)" }
      ]
    }
  ],
  "presets": [{ "name": "Social Video Grid (Laushe)", "category": "Laushe Sections" }]
}
{% endschema %}
