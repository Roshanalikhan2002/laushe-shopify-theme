<section class="laushe-promo-cta" style="background-color: {{ section.settings.bg_color }};" id="section-{{ section.id }}">
  <div class="container container-narrow">
    <div class="promo-cta-content text-center">
      <h2 class="promo-headline">{{ section.settings.headline }}</h2>
      
      <div class="promo-action">
        <a href="{{ section.settings.cta_link }}" class="promo-button">
          {{ section.settings.cta_text }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }}.laushe-promo-cta {
    padding: 100px 0;
    color: white;
  }
  
  #section-{{ section.id }} .promo-headline {
    font-size: 40px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 40px;
    color: white;
    font-family: 'Poppins', sans-serif;
  }
  
  #section-{{ section.id }} .promo-button {
    display: inline-block;
    background-color: {{ section.settings.btn_color }};
    color: #000;
    padding: 18px 45px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 16px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-transform: capitalize;
  }
  
  #section-{{ section.id }} .promo-button:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 30px rgba(255, 240, 0, 0.4);
  }
  
  @media (max-width: 768px) {
    #section-{{ section.id }}.laushe-promo-cta {
      padding: 80px 20px;
    }
    #section-{{ section.id }} .promo-headline {
      font-size: 28px;
    }
    #section-{{ section.id }} .promo-button {
      padding: 15px 35px;
      font-size: 14px;
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Promo CTA (Laushe)",
  "settings": [
    { "id": "headline", "type": "text", "label": "Headline", "default": "Ready to Transform Your Health Naturally?" },
    { "id": "cta_text", "type": "text", "label": "CTA Text", "default": "Shop Laushe Now" },
    { "id": "cta_link", "type": "url", "label": "CTA Link" },
    { "id": "bg_color", "type": "color", "label": "Background Color", "default": "#000000" },
    { "id": "btn_color", "type": "color", "label": "Button Color", "default": "#FFFA00" }
  ],
  "presets": [{ "name": "Promo CTA (Laushe)", "category": "Laushe Sections" }]
}
{% endschema %}
