{% schema %}
{
  "name": "Social Proof (Laushe)",
  "settings": [
    {
      "id": "section_title",
      "type": "text",
      "label": "Section Title",
      "default": "Pure, Potent, Proven"
    },
    {
      "id": "section_subtitle",
      "type": "text",
      "label": "Section Subtitle",
      "default": "Here is what our customers report after 3 months of using Laushe products."
    },
    {
       "id": "bg_color",
       "type": "color",
       "label": "Background Color",
       "default": "#FFF9E9"
    }
  ],
  "blocks": [
    {
      "type": "social_stat",
      "name": "Stat Box",
      "limit": 4,
      "settings": [
        {
          "id": "number",
          "type": "text",
          "label": "Stat Number",
          "default": "95%"
        },
        {
          "id": "label",
          "type": "text",
          "label": "Stat Label",
          "default": "Overall health improved"
        }
      ]
    },
    {
      "type": "social_logo",
      "name": "Trust Logo",
      "settings": [
        {
          "id": "image",
          "type": "image_picker",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
     {
       "name": "Social Proof",
       "category": "Laushe Sections"
     }
  ]
}
{% endschema %}

<section class="social-proof-laushe section-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="container text-center">
    <h2 class="social-proof-heading">{{ section.settings.section_title }}</h2>
    <p class="social-proof-subtext">{{ section.settings.section_subtitle }}</p>
    
    <div class="quick-stats-row">
      {% for block in section.blocks %}
        {% if block.type == 'social_stat' %}
          <div class="stat-box" {{ block.shopify_attributes }}>
            <div class="stat-number">{{ block.settings.number }}</div>
            <p class="stat-label-bold">{{ block.settings.label }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% assign logos_exist = false %}
    {% for block in section.blocks %}{% if block.type == 'social_logo' %}{% assign logos_exist = true %}{% break %}{% endif %}{% endfor %}

    {% if logos_exist %}
      <div class="logos-divider"></div>
      <div class="logos-track-laushe">
        {% for block in section.blocks %}
          {% if block.type == 'social_logo' %}
            <div class="logo-item-laushe" {{ block.shopify_attributes }}>
              {% if block.settings.image %}
                <img src="{{ block.settings.image | img_url: '200x' }}" alt="Trust Logo">
              {% else %}
                <span class="placeholder-logo-text">TRUST LOGO</span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .social-proof-laushe {
    padding: 100px 0;
  }
  .social-proof-heading {
    font-size: 40px;
    margin-bottom: 10px;
    color: #004225;
  }
  .social-proof-subtext {
    margin-bottom: 60px;
    font-weight: 600;
    color: #555;
  }
  .quick-stats-row {
    display: flex;
    justify-content: space-around;
    gap: 20px;
    margin-bottom: 40px;
  }
  .stat-box {
    flex: 1;
  }
  .stat-number {
    font-size: 48px;
    font-weight: 800;
    color: #004225;
    line-height: 1.2;
  }
  .stat-label-bold {
    font-weight: 800;
    font-size: 14px;
    color: #333;
    margin-top: 10px;
  }
  .logos-divider {
    height: 1px;
    background: rgba(0,66,37,0.1);
    margin: 60px auto 40px;
    max-width: 800px;
  }
  .logos-track-laushe {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
    opacity: 0.6;
  }
  .logo-item-laushe img {
    max-height: 40px;
    filter: grayscale(100%);
    transition: all 0.3s ease;
  }
  .logo-item-laushe img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
  .placeholder-logo-text {
    font-weight: 900;
    font-size: 12px;
    color: #CCC;
    letter-spacing: 2px;
  }

  @media (max-width: 768px) {
    .social-proof-heading { font-size: 32px; }
    .quick-stats-row { flex-direction: column; gap: 40px; }
    .stat-number { font-size: 40px; }
    .logos-track-laushe { gap: 20px; }
  }
</style>
