{% style %}
  /* COLLECTION HEADER */
  .collection-hero { background: #004225; color: #FFF; padding: 80px 0; text-align: center; }
  .collection-hero h1 { font-size: 48px; margin: 0 0 15px 0; color: #D4AF37; }
  .collection-hero p { font-size: 18px; max-width: 600px; margin: 0 auto; opacity: 0.9; }

  /* FILTER TABS (AG1 Style) */
  .filter-nav { background: #FFF; padding: 20px 0; border-bottom: 1px solid #EEE; position: sticky; top: 0; z-index: 100; }
  .tab-list { display: flex; justify-content: center; gap: 40px; list-style: none; margin: 0; padding: 0; }
  .tab-link { font-weight: 600; color: #888; text-decoration: none; padding-bottom: 5px; border-bottom: 2px solid transparent; transition: 0.3s; cursor: pointer; text-transform: uppercase; font-size: 13px; letter-spacing: 1px; }
  .tab-link.active, .tab-link:hover { color: #004225; border-bottom-color: #004225; }

  /* PRODUCT GRID */
  .grid-section { padding: 60px 0; background: #FAFAFA; min-height: 400px; }
  .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; transition: opacity 0.3s ease; }
  
  /* PRODUCT CARD */
  .product-card { background: #FFF; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); position: relative; display: block; }
  .product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
  .product-img { width: 100%; height: 320px; object-fit: cover; background: #F4F4F4; display: block; }
  
  .best-seller-badge { position: absolute; top: 15px; left: 15px; background: #D4AF37; color: #FFF; font-size: 10px; font-weight: 800; padding: 4px 12px; border-radius: 50px; text-transform: uppercase; z-index: 2; }
  
  .product-info { padding: 25px; text-align: center; }
  .product-title { font-size: 18px; margin: 0 0 8px 0; font-weight: 700; color: #333; }
  .product-desc { font-size: 13px; color: #777; margin-bottom: 15px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 40px; }
  .product-price { font-weight: 800; font-size: 17px; color: #004225; margin-bottom: 15px; display: block; }
  
  .btn-add { background: #E8F3EE; color: #004225; width: 100%; border: none; padding: 14px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: 0.3s; font-size: 14px; display: block; text-align: center; text-decoration: none; }
  .btn-add:hover { background: #004225; color: #FFF; }

  .collection-group--hidden { display: none !important; }

  @media (max-width: 991px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .product-info { padding: 15px; }
    .product-title { font-size: 14px; margin-bottom: 5px; }
    .product-desc { font-size: 11px; height: 34px; margin-bottom: 10px; }
    .product-price { font-size: 15px; margin-bottom: 10px; }
    .product-img { height: 180px; }
    .btn-add { padding: 10px; font-size: 12px; }
    
    .tab-list { gap: 15px; overflow-x: auto; padding: 0 20px 10px; justify-content: flex-start; -webkit-overflow-scrolling: touch; }
    .tab-link { white-space: nowrap; font-size: 11px; }
  }
{% endstyle %}

<!-- HERO -->
<header class="collection-hero">
    <div class="container-wide">
        <h1>{{ collection.title | default: 'Wellness Essentials' }}</h1>
        <p>{{ collection.description | default: 'Pure, Sunnah-blessed health solutions crafted for your modern lifestyle.' }}</p>
    </div>
</header>

<!-- FILTER TABS -->
<nav class="filter-nav">
    <div class="container-wide">
        <ul class="tab-list" id="CollectionFilterTabs">
            <li><a href="javascript:void(0)" class="tab-link active" data-filter="all">Shop All</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="healthcare">Healthcare</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="organic">Organic</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="makeup">Makeup</a></li>
        </ul>
    </div>
</nav>

<main class="grid-section">
    <div class="container-wide">
        <div class="product-grid" id="ProductGrid">
            {% for product in collection.products %}
                {% assign prod_title = product.title | downcase %}
                {% if product.handle contains 'elixir' or product.handle contains 'weight-gainer' or prod_title contains 'weight gainer' or prod_title contains 'golden elixir' %}
                    {% continue %}
                {% endif %}
                {%- assign product_tags = product.tags | join: ',' | downcase -%}
                {%- assign cat = 'general' -%}
                {%- if product_tags contains 'healthcare' or product_tags contains 'health' -%}
                  {%- assign cat = cat | append: ' healthcare' -%}
                {%- endif -%}
                {%- if product_tags contains 'organic' or product_tags contains 'natural' -%}
                  {%- assign cat = cat | append: ' organic' -%}
                {%- endif -%}
                {%- if product_tags contains 'bundle' or product_tags contains 'pack' -%}
                  {%- assign cat = cat | append: ' bundle' -%}
                {%- endif -%}
                {%- if product.handle contains 'skin-tint' or product.handle contains 'liquid-blush' or product_tags contains 'makeup' or product_tags contains 'blush' -%}
                  {%- assign cat = cat | append: ' makeup' -%}
                {%- endif -%}

                <div class="product-card collection-group {% if product.handle contains 'skin-tint' or product.handle contains 'liquid-blush' %}collection-group--hidden{% endif %}" data-category="{{ cat }}" {% if product.handle contains 'skin-tint' or product.handle contains 'liquid-blush' %}data-exclusive="makeup"{% endif %}>
                    {% if product.tags contains 'Best Seller' or product.tags contains 'best-seller' %}
                        <div class="best-seller-badge">Best Seller</div>
                    {% endif %}
                    
                    {% assign prod_img = product.featured_image | img_url: '600x800', crop: 'center' %}
                    {% if product.handle contains 'hair-oil' %}
                        {% assign prod_img = 'hair-oil-v2.jpg' | asset_url %}
                    {% endif %}

                    <a href="{{ product.url }}">
                        <img src="{{ prod_img }}" class="product-img" alt="{{ product.title }}" loading="lazy">
                    </a>
                    
                    <div class="product-info">
                        <h3 class="product-title">{{ product.title }}</h3>
                        <p class="product-desc">{{ product.metafields.custom.short_description | default: 'Premium wellness essential for your daily routine.' }}</p>
                        <span class="product-price">{{ product.price | money }}</span>
                        
                        <form method="post" action="/cart/add" class="laushe-collection-atc">
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn-add">
                                <span class="atc-text">Add to Cart</span>
                                <span class="atc-loading" style="display: none;">Adding...</span>
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="text-center" style="width: 100%; padding: 40px;">
                   <p>No products found in this collection.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const tabs = document.querySelectorAll('.tab-link');
        const groups = document.querySelectorAll('.collection-group');
        const grid = document.getElementById('ProductGrid');

        function applyFilter(filter, bypassAnimation = false) {
            if (!bypassAnimation) grid.style.opacity = '0.3';
            
            setTimeout(() => {
                groups.forEach(group => {
                    const categories = group.getAttribute('data-category');
                    const isExclusive = group.getAttribute('data-exclusive');
                    
                    if (filter === 'all') {
                        if (isExclusive) {
                            group.classList.add('collection-group--hidden');
                        } else {
                            group.classList.remove('collection-group--hidden');
                        }
                    } else {
                        if (categories.includes(filter)) {
                            group.classList.remove('collection-group--hidden');
                        } else {
                            group.classList.add('collection-group--hidden');
                        }
                    }
                });
                if (!bypassAnimation) grid.style.opacity = '1';
            }, bypassAnimation ? 0 : 200);
        }

        tabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                const filter = tab.getAttribute('data-filter');
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                applyFilter(filter);
                
                // Update URL without refreshing
                const newUrl = window.location.pathname + '?filter=' + filter;
                window.history.pushState({path:newUrl},'',newUrl);
            });
        });

        // HANDLE DEEP LINKING FROM HEADER
        const urlParams = new URLSearchParams(window.location.search);
        const externalFilter = urlParams.get('filter');
        if (externalFilter) {
            const targetTab = Array.from(tabs).find(t => t.getAttribute('data-filter') === externalFilter);
            if (targetTab) {
                targetTab.click();
                // Smooth scroll to grid
                const gridTop = document.getElementById('CollectionFilterTabs').offsetTop;
                window.scrollTo({ top: gridTop - 100, behavior: 'smooth' });
            }
        }

        // AJAX ADD TO CART
        const atcForms = document.querySelectorAll('.laushe-collection-atc');
        atcForms.forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const btn = form.querySelector('.btn-add');
                const atcText = btn.querySelector('.atc-text');
                const atcLoading = btn.querySelector('.atc-loading');
                const variantId = form.querySelector('input[name="id"]').value;

                if (!variantId) {
                  alert('Please select a valid product variant.');
                  return;
                }

                atcText.style.display = 'none';
                atcLoading.style.display = 'inline';
                btn.style.opacity = '0.7';
                btn.disabled = true;

                fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
                })
                .then(res => {
                    if (!res.ok) throw new Error('Cart add failed');
                    return res.json();
                })
                .then(data => {
                    // Success visual
                    atcLoading.style.display = 'none';
                    atcText.style.display = 'inline';
                    atcText.innerText = 'Added! ✓';
                    btn.style.background = '#4CAF50';
                    btn.style.color = '#FFF';
                    btn.style.opacity = '1';

                    // Trigger cart drawer
                    if (window.LausheCart) {
                        LausheCart.open();
                    } else {
                        document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
                    }

                    setTimeout(() => {
                        atcText.innerText = 'Add to Cart';
                        btn.style.background = '';
                        btn.style.color = '';
                        btn.disabled = false;
                    }, 2000);
                })
                .catch(err => {
                    console.error('ATC error:', err);
                    atcLoading.style.display = 'none';
                    atcText.style.display = 'inline';
                    atcText.innerText = 'Error!';
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    setTimeout(() => {
                        atcText.innerText = 'Add to Cart';
                    }, 2500);
                });
            });
        });
    });
</script>

{% schema %}
{
  "name": "Collection Grid AG1",
  "settings": [],
  "presets": [
    {
      "name": "Collection Grid AG1"
    }
  ]
}
{% endschema %}
