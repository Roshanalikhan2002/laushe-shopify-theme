{% style %}
  /* COLLECTION HEADER */
  .collection-hero { background: var(--primary-green); color: #FFF; padding: 80px 0; text-align: center; }
  .collection-hero h1 { font-size: 48px; margin: 0 0 15px 0; color: var(--accent-gold); }
  .collection-hero p { font-size: 18px; max-width: 600px; margin: 0 auto; opacity: 0.9; }

  /* FILTER TABS (AG1 Style) */
  .filter-nav { background: #FFF; padding: 20px 0; border-bottom: 1px solid #EEE; position: sticky; top: 0; z-index: 100; }
  .tab-list { display: flex; justify-content: center; gap: 40px; list-style: none; margin: 0; padding: 0; }
  .tab-link { font-weight: 600; color: #888; text-decoration: none; padding-bottom: 5px; border-bottom: 2px solid transparent; transition: 0.3s; cursor: pointer; }
  .tab-link.active, .tab-link:hover { color: var(--primary-green); border-bottom-color: var(--primary-green); }

  /* PRODUCT GRID */
  .grid-section { padding: 60px 0; background: #FAFAFA; }
  .grid-title { font-size: 32px; border-bottom: 2px solid #EEE; padding-bottom: 15px; margin-bottom: 40px; }
  .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  
  /* PRODUCT CARD */
  .product-card { background: #FFF; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-luxe); transition: 0.3s; position: relative; }
  .product-card:hover { transform: translateY(-5px); }
  .product-img { width: 100%; height: 280px; object-fit: cover; background: #EEE; }
  .best-seller-badge { position: absolute; top: 15px; left: 15px; background: var(--accent-gold); color: #FFF; font-size: 11px; font-weight: 800; padding: 5px 12px; border-radius: 50px; text-transform: uppercase; }
  
  .product-info { padding: 25px; }
  .product-title { font-size: 20px; margin: 0 0 10px 0; }
  .product-desc { font-size: 14px; color: #666; margin-bottom: 20px; line-height: 1.5; }
  .product-price { font-weight: 800; font-size: 18px; color: var(--primary-green); margin-bottom: 20px; display: block; }
  
  .btn-add { background: var(--soft-mint); color: var(--primary-green); width: 100%; border: none; padding: 15px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: 0.3s; font-size: 15px; display: block; text-align: center; text-decoration: none; box-sizing: border-box; }
  .btn-add:hover { background: var(--primary-green); color: #FFF; }

  @media (max-width: 768px) {
      .product-grid { grid-template-columns: 1fr; }
      .tab-list { gap: 20px; overflow-x: auto; padding-bottom: 10px; }
  }
{% endstyle %}

<!-- HERO -->
<header class="collection-hero">
    <div class="container-wide">
        <h1>{{ collection.title | default: 'All Products' }}</h1>
        <p>{{ collection.description | default: 'Laushe is so much more than weight loss. Discover our pure organic and healthcare essentials.' }}</p>
    </div>
</header>

<!-- AG1 STYLE FILTER TABS -->
<nav class="filter-nav">
    <div class="container-wide">
        <ul class="tab-list">
            <li><a href="javascript:void(0)" class="tab-link active" data-filter="all">Shop All</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="healthcare">Healthcare</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="organic">Organic Products</a></li>
            <li><a href="javascript:void(0)" class="tab-link" data-filter="bundles">Bundles & Save</a></li>
        </ul>
    </div>
</nav>

<main class="grid-section">
    <div class="container-wide">
        <div class="product-grid" style="margin-bottom: 80px;">
            {% for product in collection.products %}
                <div class="product-card collection-group" data-category="{% if product.tags contains 'healthcare' %}healthcare{% elsif product.tags contains 'organic' %}organic{% else %}general{% endif %}">
                    {% if forloop.first %}
                        <div class="best-seller-badge">#1 Best Seller</div>
                    {% endif %}
                    
                    <a href="{{ product.url }}">
                        <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" class="product-img" alt="{{ product.title }}">
                    </a>
                    
                    <div class="product-info">
                        <h3 class="product-title">{{ product.title }}</h3>
                        <p class="product-desc">{{ product.metafields.custom.short_description | default: 'Premium wellness essential for your daily routine.' }}</p>
                        <span class="product-price">{{ product.price | money }}</span>
                        
                        <form method="post" action="/cart/add">
                            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                            <button type="submit" class="btn-add">Add to Cart</button>
                        </form>
                    </div>
                </div>
            {% else %}
                <p>No products found in this collection.</p>
            {% endfor %}
        </div>
    </div>
</main>

<script>
    // Real Filter Functionality based on product tags applied to the card
    document.addEventListener("DOMContentLoaded", function() {
        const tabs = document.querySelectorAll('.tab-link');
        const groups = document.querySelectorAll('.collection-group');

        tabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                
                tabs.forEach(t => t.classList.remove('active'));
                e.target.classList.add('active');

                const filter = e.target.getAttribute('data-filter');
                groups.forEach(group => {
                    if (filter === 'all') {
                        group.style.display = 'block';
                    } else if (filter === 'bundles') {
                        group.style.display = 'none'; 
                    } else {
                        if (group.getAttribute('data-category').includes(filter)) {
                            group.style.display = 'block';
                        } else {
                            group.style.display = 'none';
                        }
                    }
                });
            });
        });
    });
</script>

{% schema %}
{
  "name": "Collection Grid AG1",
  "settings": [],
  "presets": [
    {
      "name": "Collection Grid AG1"
    }
  ]
}
{% endschema %}
